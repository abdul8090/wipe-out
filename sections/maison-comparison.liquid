{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "class": "section section-compare",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SUPERIOR IN EVERY WAY"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "brand_heading",
      "label": "Your Brand Column Heading",
      "default": "YOUR BRAND"
    },
    {
      "type": "text",
      "id": "others_heading",
      "label": "Others Column Heading",
      "default": "OTHERS"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Image"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    }
  ],
  "blocks": [
    {
      "type": "comparison_item",
      "name": "Comparison Item",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Feature"
        },
        {
          "type": "checkbox",
          "id": "your_brand_has",
          "label": "Your Brand Has This Feature",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "others_have",
          "label": "Others Have This Feature",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        {
          "type": "comparison_item",
          "settings": {
            "feature": "100% Natural Ingredients",
            "your_brand_has": true,
            "others_have": false
          }
        },
        {
          "type": "comparison_item",
          "settings": {
            "feature": "Grass Fed, Grass Finished",
            "your_brand_has": true,
            "others_have": false
          }
        },
        {
          "type": "comparison_item",
          "settings": {
            "feature": "No Preservatives",
            "your_brand_has": true,
            "others_have": false
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="padding-global">
  <div class="container-large container-large_relative">
    <div class="padding-section">
      <div class="compare-component">
        <div class="compare-content">
          <h2 class="heading-h2">{{ section.settings.heading }}</h2>
          <div class="compare-table">
            <div class="table-row table-row_head">
              <div class="table-cell-heading-left"></div>
              <div class="table-cell-heading">
                <div class="table-heading">
                  {% if section.settings.logo != blank %}
                    {{
                      section.settings.logo
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        sizes: '(max-width: 600px) 100vw, 600px',
                        widths: '500, 600',
                        class: 'logo',
                        alt: section.settings.brand_heading
                    }}
                  {% else %}
                    {{ section.settings.brand_heading }}
                  {% endif %}
                </div>
              </div>
              <div class="table-cell-heading-right">
                <div class="table-heading">{{ section.settings.others_heading }}</div>
              </div>
            </div>

            {% for block in section.blocks %}
              {% assign is_first = forloop.first %}
              {% assign is_last = forloop.last %}

              <div class="table-row" {{ block.shopify_attributes }}>
                <div class="table-cell-left{% if is_first %} top{% endif %}{% if is_last %} bottom{% endif %}">
                  <div>{{ block.settings.feature }}</div>
                </div>
                <div class="table-cell">
                  {% if block.settings.your_brand_has %}
                    <div class="svg table w-embed">
                      <svg width="48" height="48" viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M24 4.5C20.1433 4.5 16.3731 5.64366 13.1664 7.78634C9.95963 9.92903 7.46027 12.9745 5.98436 16.5377C4.50845 20.1008 4.12228 24.0216 4.8747 27.8043C5.62711 31.5869 7.4843 35.0615 10.2114 37.7886C12.9386 40.5157 16.4131 42.3729 20.1957 43.1253C23.9784 43.8777 27.8992 43.4916 31.4623 42.0156C35.0255 40.5397 38.071 38.0404 40.2137 34.8336C42.3564 31.6269 43.5 27.8567 43.5 24C43.4901 18.8313 41.4325 13.8772 37.7776 10.2224C34.1228 6.56755 29.1687 4.50991 24 4.5ZM33.2813 20.5875L22.2938 31.0875C22.0097 31.3547 21.6337 31.5024 21.2438 31.5C21.0531 31.5027 20.8639 31.4677 20.6869 31.3969C20.5099 31.3261 20.3487 31.2209 20.2125 31.0875L14.7188 25.8375C14.5664 25.7046 14.4425 25.5422 14.3544 25.3601C14.2664 25.1781 14.2161 24.9801 14.2066 24.7781C14.197 24.5761 14.2284 24.3743 14.2988 24.1847C14.3693 23.9952 14.4773 23.8218 14.6164 23.6751C14.7556 23.5283 14.923 23.4113 15.1085 23.3309C15.2941 23.2505 15.494 23.2084 15.6962 23.2072C15.8984 23.2061 16.0988 23.2458 16.2852 23.324C16.4717 23.4023 16.6404 23.5174 16.7813 23.6625L21.2438 27.9187L31.2188 18.4125C31.5104 18.158 31.8891 18.0262 32.2758 18.0445C32.6624 18.0628 33.027 18.2298 33.2933 18.5107C33.5597 18.7915 33.7071 19.1644 33.7049 19.5515C33.7026 19.9386 33.5508 20.3098 33.2813 20.5875Z" fill="#2C2609"></path>
                      </svg>
                    </div>
                  {% else %}
                    <div class="svg table w-embed">
                      <svg width="48" height="48" viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M24 42C33.9411 42 42 33.9411 42 24C42 14.0589 33.9411 6 24 6C14.0589 6 6 14.0589 6 24C6 33.9411 14.0589 42 24 42Z" stroke="#2C2609" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                        <path d="M16.5 24H31.5" stroke="#2C2609" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </div>
                  {% endif %}
                </div>
                <div class="table-cell-right{% if is_first %} top{% endif %}{% if is_last %} bottom{% endif %}">
                  {% if block.settings.others_have %}
                    <div class="svg table w-embed">
                      <svg width="48" height="48" viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M24 4.5C20.1433 4.5 16.3731 5.64366 13.1664 7.78634C9.95963 9.92903 7.46027 12.9745 5.98436 16.5377C4.50845 20.1008 4.12228 24.0216 4.8747 27.8043C5.62711 31.5869 7.4843 35.0615 10.2114 37.7886C12.9386 40.5157 16.4131 42.3729 20.1957 43.1253C23.9784 43.8777 27.8992 43.4916 31.4623 42.0156C35.0255 40.5397 38.071 38.0404 40.2137 34.8336C42.3564 31.6269 43.5 27.8567 43.5 24C43.4901 18.8313 41.4325 13.8772 37.7776 10.2224C34.1228 6.56755 29.1687 4.50991 24 4.5ZM33.2813 20.5875L22.2938 31.0875C22.0097 31.3547 21.6337 31.5024 21.2438 31.5C21.0531 31.5027 20.8639 31.4677 20.6869 31.3969C20.5099 31.3261 20.3487 31.2209 20.2125 31.0875L14.7188 25.8375C14.5664 25.7046 14.4425 25.5422 14.3544 25.3601C14.2664 25.1781 14.2161 24.9801 14.2066 24.7781C14.197 24.5761 14.2284 24.3743 14.2988 24.1847C14.3693 23.9952 14.4773 23.8218 14.6164 23.6751C14.7556 23.5283 14.923 23.4113 15.1085 23.3309C15.2941 23.2505 15.494 23.2084 15.6962 23.2072C15.8984 23.2061 16.0988 23.2458 16.2852 23.324C16.4717 23.4023 16.6404 23.5174 16.7813 23.6625L21.2438 27.9187L31.2188 18.4125C31.5104 18.158 31.8891 18.0262 32.2758 18.0445C32.6624 18.0628 33.027 18.2298 33.2933 18.5107C33.5597 18.7915 33.7071 19.1644 33.7049 19.5515C33.7026 19.9386 33.5508 20.3098 33.2813 20.5875Z" fill="#2C2609"></path>
                      </svg>
                    </div>
                  {% else %}
                    <div class="svg table w-embed">
                      <svg width="48" height="48" viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M24 42C33.9411 42 42 33.9411 42 24C42 14.0589 33.9411 6 24 6C14.0589 6 6 14.0589 6 24C6 33.9411 14.0589 42 24 42Z" stroke="#2C2609" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                        <path d="M16.5 24H31.5" stroke="#2C2609" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}

            <div class="table-row">
              <div class="table-cell-bottom-left"></div>
              <div class="table-cell-bottom"></div>
              <div class="table-cell-bottom-right"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% if section.settings.left_image != blank %}
      {{
        section.settings.left_image
        | image_url: width: 800
        | image_tag: loading: 'lazy', alt: '', class: 'cream-image'
      }}
    {% endif %}

    {% if section.settings.right_image != blank %}
      {{
        section.settings.right_image
        | image_url: width: 800
        | image_tag: loading: 'lazy', alt: '', class: 'cream-image cream-image-second'
      }}
    {% endif %}
  </div>
</div>
