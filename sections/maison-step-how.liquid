  ],
  "presets": [
    {
      "name": "How It Works Steps",
      "blocks": [
        {
          "type": "step",
          "settings": { "step_number": "STEP 1", "title": "APPLY" }
        },
        {
          "type": "step",
          "settings": { "step_number": "STEP 2", "title": "GET APPROVED" }
        },
        {
          "type": "step",
          "settings": { "step_number": "STEP 3", "title": "START EARNING" }
        }
      ]
