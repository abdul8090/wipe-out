{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "class": "section section-compare",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SUPERIOR IN EVERY WAY"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "brand_heading",
      "label": "Your Brand Column Heading",
      "default": "YOUR BRAND"
    },
    {
      "type": "text",
      "id": "others_heading",
      "label": "Others Column Heading",
      "default": "OTHERS"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Image"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding (desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding (mobile)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Font sizes — desktop"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading",
      "default": 48
    },
    {
      "type": "range",
      "id": "feature_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Feature text",
      "default": 18
    },
    {
      "type": "range",
      "id": "col_heading_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Column headings",
      "default": 18
    },
    {
      "type": "header",
      "content": "Font sizes — tablet"
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Heading",
      "default": 36
    },
    {
      "type": "range",
      "id": "feature_size_tablet",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Feature text",
      "default": 14
    },
    {
      "type": "range",
      "id": "col_heading_size_tablet",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Column headings",
      "default": 14
    },
    {
      "type": "header",
      "content": "Font sizes — mobile"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading",
      "default": 28
    },
    {
      "type": "range",
      "id": "feature_size_mobile",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Feature text",
      "default": 13
    },
    {
      "type": "range",
      "id": "col_heading_size_mobile",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Column headings",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#fefcf3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Brand column colour",
      "default": "#fedb36"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Table border colour",
      "default": "#2c2609"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & heading colour",
      "default": "#1d211e"
    },
    {
      "type": "color",
      "id": "cell_bg",
      "label": "Table cell background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon colour",
      "default": "#2c2609"
    }
  ],
  "blocks": [
    {
      "type": "comparison_item",
      "name": "Comparison Item",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Feature"
        },
        {
          "type": "checkbox",
          "id": "your_brand_has",
          "label": "Your Brand Has This Feature",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "others_have",
          "label": "Others Have This Feature",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        {
          "type": "comparison_item",
          "settings": {
            "feature": "100% Natural Ingredients",
            "your_brand_has": true,
            "others_have": false
          }
        },
        {
          "type": "comparison_item",
          "settings": {
            "feature": "Grass Fed, Grass Finished",
            "your_brand_has": true,
            "others_have": false
          }
        },
        {
          "type": "comparison_item",
          "settings": {
            "feature": "No Preservatives",
            "your_brand_has": true,
            "others_have": false
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
    
#shopify-section-{{ section.id }} {
  --text--secondary: #121212bf;
  --browndark: {{ section.settings.border_color }};
  --yellow-b1--200: {{ section.settings.bg_color }};
  --text--primary: {{ section.settings.text_color }};
  --white: {{ section.settings.cell_bg }};
  --gray-75: #0000001f;
  --yellow-b1--1800: {{ section.settings.accent_color }};
  --red: #f63208;
  --yellow-b1--300: #fbf9f2;
  --gray-500: #98a2b3;
  --yellow-b1--100: #fedb361f;
  --gray-100: #f2f2f0;
  --black: black;
  --transparent: transparent;
  --gray-50: #00000014;
}

#shopify-section-{{ section.id }} .svg.table svg {
  color: {{ section.settings.icon_color }};
}

#shopify-section-{{ section.id }} .padding-global {
  padding-left: {{ section.settings.padding_horizontal }}px;
  padding-right: {{ section.settings.padding_horizontal }}px;
}

#shopify-section-{{ section.id }} .padding-section {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

@media screen and (max-width: 991px) {
  #shopify-section-{{ section.id }} .padding-global {
    padding-left: 32px;
    padding-right: 32px;
  }

  #shopify-section-{{ section.id }} .padding-section {
    padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px;
  }
}

@media screen and (max-width: 767px) {
  #shopify-section-{{ section.id }} .padding-global {
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
  }

  #shopify-section-{{ section.id }} .padding-section {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round }}px;
  }
}

/* Font size overrides — scoped to this section */
#shopify-section-{{ section.id }} .heading-h2 {
  font-size: {{ section.settings.heading_size }}px;
}

#shopify-section-{{ section.id }} .table-cell-left {
  font-size: {{ section.settings.feature_size }}px;
}

#shopify-section-{{ section.id }} .table-heading {
  font-size: {{ section.settings.col_heading_size }}px;
}

@media screen and (max-width: 991px) {
  #shopify-section-{{ section.id }} .heading-h2 {
    font-size: {{ section.settings.heading_size_tablet }}px;
  }

  #shopify-section-{{ section.id }} .table-cell-left {
    font-size: {{ section.settings.feature_size_tablet }}px;
  }

  #shopify-section-{{ section.id }} .table-heading {
    font-size: {{ section.settings.col_heading_size_tablet }}px;
  }
}

@media screen and (max-width: 767px) {
  #shopify-section-{{ section.id }} .heading-h2 {
    font-size: {{ section.settings.heading_size_mobile }}px;
  }

  #shopify-section-{{ section.id }} .table-cell-left {
    font-size: {{ section.settings.feature_size_mobile }}px;
  }

  #shopify-section-{{ section.id }} .table-heading {
    font-size: {{ section.settings.col_heading_size_mobile }}px;
  }
}

#shopify-section-{{ section.id }} .body {
  color: var(--text--secondary);
  font-size: 16px;
  line-height: 1.5;
}

#shopify-section-{{ section.id }} .label {
  grid-column-gap: 4px;
  grid-row-gap: 4px;
  border: 1px solid var(--browndark);
  background-color: var(--yellow-b1--200);
  color: var(--text--primary);
  border-radius: 999px;
  justify-content: flex-start;
  align-items: center;
  padding: 4px 8px;
  font-size: 14px;
  font-weight: 700;
  line-height: 1;
  display: flex;
}

#shopify-section-{{ section.id }} .slider_mask {
  width: 22%;
  margin-left: -12px;
  overflow: visible;
}

#shopify-section-{{ section.id }} .padding-section {
  padding-top: 56px;
  padding-bottom: 56px;
}

#shopify-section-{{ section.id }} .padding-section.padding-section_entry {
  padding-top: 64px;
  padding-bottom: 64px;
}

#shopify-section-{{ section.id }} .slider {
  background-color: #0000;
  height: auto;
  padding-bottom: 96px;
  position: relative;
}

#shopify-section-{{ section.id }} .slider.slider-hero {
  border: 6px solid var(--white);
  width: 550px;
  height: 320px;
  padding-bottom: 0;
  box-shadow: 0 12px 16px -4px #10182814, 0 4px 6px -2px #10182808;
}

#shopify-section-{{ section.id }} .section.section-slider {
  grid-column-gap: 40px;
  grid-row-gap: 40px;
  flex-flow: column;
  padding-top: 56px;
  padding-bottom: 56px;
  display: flex;
  overflow: hidden;
}

#shopify-section-{{ section.id }} .section.section-entry {
  background-color: var(--yellow-b1--200);
}

#shopify-section-{{ section.id }} .section.section-compare {
  background-color: var(--yellow-b1--200);
}

#shopify-section-{{ section.id }} .section.section-horizontal-scroll.yellow {
  background-color: var(--yellow-b1--200);
}

#shopify-section-{{ section.id }} .slide-review__title {
  color: #40352f;
  text-transform: uppercase;
  font-size: 24px;
  font-weight: 700;
  line-height: 1.4;
}

#shopify-section-{{ section.id }} .stars {
  flex: 0 auto;
  justify-content: flex-start;
  align-items: center;
  text-decoration: none;
  display: flex;
}

#shopify-section-{{ section.id }} .slide-card__inner {
  grid-column-gap: 24px;
  grid-row-gap: 24px;
  text-align: center;
  flex-flow: column;
  justify-content: flex-start;
  align-items: center;
  display: flex;
  position: relative;
}

#shopify-section-{{ section.id }} .badge {
  grid-column-gap: 8px;
  grid-row-gap: 8px;
  border: 1px solid var(--browndark);
  background-color: var(--white);
  color: #4b3c36;
  text-align: center;
  border-radius: 999px;
  flex-flow: wrap;
  flex: 0 auto;
  justify-content: center;
  align-items: center;
  padding: 8px 12px;
  font-size: 14px;
  line-height: 1;
  display: flex;
}

#shopify-section-{{ section.id }} .wo-badge {
  grid-column-gap: 8px;
  grid-row-gap: 8px;
/*   border: 1px solid var(--browndark);
  background-color: var(--white); */
  color: #4b3c36;
  text-align: center;
  border-radius: 999px;
  flex-flow: wrap;
  flex: 0 auto;
  justify-content: center;
  align-items: center;
  padding: 8px 12px;
  font-size: 14px;
  line-height: 1;
  display: flex;
}

#shopify-section-{{ section.id }} .customers-slider-content_slide-nav {
  height: 28px;
  font-size: 8px;
  inset: auto auto 0% 80px;
}

#shopify-section-{{ section.id }} .bold-900 {
  font-weight: 900;
}

#shopify-section-{{ section.id }} .customers-slider-component {
  flex-flow: column;
  justify-content: flex-start;
  align-items: center;
  display: flex;
}

#shopify-section-{{ section.id }} .container-large {
  width: 100%;
  max-width: 1280px;
  margin-left: auto;
  margin-right: auto;
}

#shopify-section-{{ section.id }} .container-large.container-large_relative {
  position: relative;
}

#shopify-section-{{ section.id }} .slide-card {
  flex-flow: column;
  justify-content: flex-start;
  align-items: center;
  width: 100%;
  display: flex;
  overflow: hidden;
}

#shopify-section-{{ section.id }} .global-styles {
  display: block;
  position: fixed;
  inset: 0% auto auto 0%;
}

#shopify-section-{{ section.id }} .heading {
  z-index: 2;
  grid-column-gap: 16px;
  grid-row-gap: 16px;
  text-align: center;
  flex-flow: column;
  max-width: 600px;
  display: flex;
  position: relative;
}

#shopify-section-{{ section.id }} .svg {
  justify-content: center;
  align-items: center;
  display: flex;
}

#shopify-section-{{ section.id }} .svg.play {
  position: absolute;
}

#shopify-section-{{ section.id }} .svg.arrow {
  margin-top: 60px;
}

#shopify-section-{{ section.id }} .slider-customers_shade {
  z-index: 1;
  pointer-events: none;
  background-image: linear-gradient(90deg, #fff, #0000);
  width: 80px;
  height: 100%;
  position: absolute;
  inset: 0% auto 0% 0%;
}

#shopify-section-{{ section.id }} .slider-customers_shade.slider-customers_shade-right {
  background-image: linear-gradient(90deg, #0000, #fff);
  inset: 0% 0% 0% auto;
}

#shopify-section-{{ section.id }} .padding-global {
  padding-left: 80px;
  padding-right: 80px;
}

#shopify-section-{{ section.id }} .slider-arrow {
  border: 1px solid var(--browndark);
  background-color: var(--white);
  border-radius: 12px;
  justify-content: center;
  align-items: center;
  width: 56px;
  height: 56px;
  display: flex;
  box-shadow: 0 4px #2c2609;
}

#shopify-section-{{ section.id }} .slider-arrow.is-bottom-previous {
  inset: auto 152px 0% auto;
}

#shopify-section-{{ section.id }} .slider-arrow.is-bottom-next {
  inset: auto 80px 0% auto;
}

#shopify-section-{{ section.id }} .slide-review__text {
  color: #0a0f2ebf;
  font-size: 14px;
}

#shopify-section-{{ section.id }} .slider_slide {
  padding-left: 12px;
  padding-right: 12px;
}

#shopify-section-{{ section.id }} .entry-component {
  grid-column-gap: 80px;
  grid-row-gap: 80px;
  justify-content: space-between;
  align-items: center;
  display: flex;
}

#shopify-section-{{ section.id }} .entry-content {
  max-width: 600px;
}

#shopify-section-{{ section.id }} .table-cell-right {
  grid-column-gap: 12px;
  grid-row-gap: 12px;
  border-right: 1px solid var(--browndark);
  border-bottom: 1px dashed var(--gray-75);
  background-color: var(--white);
  justify-content: center;
  align-items: center;
  min-width: 200px;
  height: 65px;
  padding: 8px 24px;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell-right.bottom {
  border-bottom: 1px solid var(--browndark);
  border-bottom-right-radius: 8px;
}

#shopify-section-{{ section.id }} .table-cell-right.top {
  border-top: 1px solid var(--browndark);
  border-top-right-radius: 8px;
}

#shopify-section-{{ section.id }} .table-cell-left {
  grid-column-gap: 12px;
  grid-row-gap: 12px;
  border-bottom: 1px dashed var(--gray-75);
  border-left: 1px solid var(--browndark);
  background-color: var(--white);
  color: var(--text--primary);
  text-transform: uppercase;
  justify-content: center;
  align-items: center;
  min-width: 400px;
  height: 65px;
  padding: 16px 24px;
  font-size: 18px;
  font-weight: 500;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell-left.top {
  border-top: 1px solid var(--browndark);
  border-top-left-radius: 8px;
}

#shopify-section-{{ section.id }} .table-cell-left.bottom {
  border-bottom: 1px solid var(--browndark);
  border-bottom-left-radius: 8px;
}

#shopify-section-{{ section.id }} .table-row {
  justify-content: flex-start;
  align-items: center;
  width: 100%;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell-bottom-left {
  min-width: 400px;
  height: 24px;
}

#shopify-section-{{ section.id }} .table-cell-heading-right {
  color: var(--text--primary);
  justify-content: center;
  align-items: center;
  min-width: 200px;
  height: 72px;
  padding: 24px 16px;
  font-size: 16px;
  font-weight: 700;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell-bottom {
  grid-column-gap: 12px;
  border-style: none solid solid;
  border-width: 1px;
  border-color: var(--browndark);
  background-color: var(--yellow-b1--1800);
  border-bottom-right-radius: 8px;
  border-bottom-left-radius: 8px;
  justify-content: center;
  align-items: center;
  width: 200px;
  min-width: 200px;
  height: 24px;
  padding: 12px 24px;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell-heading {
  border-style: solid solid none;
  border-width: 1px;
  border-color: var(--browndark);
  background-color: var(--yellow-b1--1800);
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
  flex-flow: row;
  justify-content: center;
  align-items: center;
  min-width: 200px;
  height: 72px;
  padding-top: 24px;
  padding-bottom: 24px;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell-bottom-right {
  min-width: 200px;
  height: 24px;
}

#shopify-section-{{ section.id }} .table-heading {
  text-align: center;
  white-space: nowrap;
  font-size: 18px;
  font-weight: 700;
}

#shopify-section-{{ section.id }} .table-cell-heading-left {
  flex-flow: row;
  justify-content: center;
  align-items: center;
  min-width: 400px;
  height: 72px;
  display: flex;
}

#shopify-section-{{ section.id }} .compare-table {
  flex-direction: column;
  width: 100%;
  display: flex;
}

#shopify-section-{{ section.id }} .table-cell {
  grid-column-gap: 12px;
  border-style: none solid;
  border-width: 1px;
  border-color: var(--browndark);
  background-color: var(--yellow-b1--1800);
  justify-content: center;
  align-items: center;
  min-width: 200px;
  height: 65px;
  padding: 8px 24px;
  display: flex;
}

#shopify-section-{{ section.id }} .heading-h1 {
  color: var(--text--primary);
  text-transform: uppercase;
  margin-top: 0;
  margin-bottom: 0;
  font-size: 56px;
  font-weight: 700;
  line-height: 1.2;
}

#shopify-section-{{ section.id }} .button {
  grid-column-gap: 12px;
  grid-row-gap: 12px;
  border: 1px solid var(--browndark);
  background-color: var(--yellow-b1--1800);
  color: var(--text--primary);
  border-radius: 12px;
  justify-content: center;
  align-items: center;
  height: 56px;
  padding: 16px;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  box-shadow: 0 4px #2c2609;
}

#shopify-section-{{ section.id }} .entry-content_inner {
  grid-column-gap: 16px;
  grid-row-gap: 16px;
  flex-flow: column;
  display: flex;
}

#shopify-section-{{ section.id }} .entry-content_inner p{
  font-style: normal;
  font-weight: 400;
  line-height: 150%;
}

#shopify-section-{{ section.id }} .entry-content_row {
  grid-column-gap: 12px;
  grid-row-gap: 12px;
  color: var(--text--primary);
  flex-flow: wrap;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  font-weight: 500;
  display: flex;
}

#shopify-section-{{ section.id }} .entry-content_row-cell {
  grid-column-gap: 8px;
  grid-row-gap: 8px;
  justify-content: flex-start;
  align-items: center;
  line-height: 1;
  display: flex;
}

#shopify-section-{{ section.id }} .divider {
  background-color: var(--browndark);
  width: 1px;
  height: 12px;
}

#shopify-section-{{ section.id }} .entry-content_heading {
  grid-column-gap: 12px;
  grid-row-gap: 12px;
  flex-flow: column;
  justify-content: flex-start;
  align-items: flex-start;
  display: flex;
}

#shopify-section-{{ section.id }} .entry-content_block {
  grid-column-gap: 32px;
  grid-row-gap: 32px;
  flex-flow: column;
  display: flex;
}

#shopify-section-{{ section.id }} .bold {
  font-weight: 700;
}

#shopify-section-{{ section.id }} .compare-component {
  flex-flow: column;
  justify-content: flex-start;
  align-items: center;
