<style>
  #shopify-section-{{ section.id }} {
    --wo-rev-bg: {{ section.settings.bg_color }};
    --wo-rev-text: {{ section.settings.text_color }};
    --wo-rev-muted: {{ section.settings.muted_color }};
    --wo-rev-border: {{ section.settings.border_color }};
    --wo-rev-star: {{ section.settings.star_color }};
    --wo-rev-verified: {{ section.settings.verified_color }};
  }

  .wo-rev {
    background: var(--wo-rev-bg);
    color: var(--wo-rev-text);
  }

  .wo-rev__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  .wo-rev__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .wo-rev__stars {
    display: flex;
    gap: 3px;
    justify-content: center;
    margin-bottom: 14px;
    color: var(--wo-rev-star);
  }

  .wo-rev__heading {
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 0.98;
    margin: 0;
  }

  .wo-rev__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .wo-rev__card {
    border: 1px solid var(--wo-rev-border);
    border-radius: 6px;
    padding: 30px 28px;
  }

  .wo-rev__card-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
    color: var(--wo-rev-star);
  }

  .wo-rev__quote {
    font-size: 15px;
    line-height: 1.6;
    margin: 0 0 18px;
  }

  .wo-rev__author {
    font-size: 13.5px;
    font-weight: 700;
  }

  .wo-rev__verified {
    color: var(--wo-rev-verified);
    font-weight: 600;
    font-size: 12px;
    margin-left: 4px;
  }

  @media (max-width: 1023px) {
    .wo-rev__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 599px) {
    .wo-rev__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .wo-rev__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
</style>

{%- assign star_svg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z"></path></svg>' -%}

<section class="wo-rev">
  <div class="wo-rev__inner">
    <div class="wo-rev__header">
      <div class="wo-rev__stars">
        {%- for i in (1..5) -%}{{ star_svg }}{%- endfor -%}
      </div>
      <h2 class="wo-rev__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="wo-rev__grid">
      {%- for block in section.blocks -%}
        <div class="wo-rev__card" {{ block.shopify_attributes }}>
          <div class="wo-rev__card-stars">
            {%- assign rating = block.settings.rating -%}
            {%- for i in (1..rating) -%}{{ star_svg }}{%- endfor -%}
          </div>
          <p class="wo-rev__quote">&ldquo;{{ block.settings.review }}&rdquo;</p>
          <div class="wo-rev__author">
            {{ block.settings.author }}
            {%- if block.settings.verified -%}
              <span class="wo-rev__verified">&#10003; Verified</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WipeOut Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by 12,000+ homes"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    },
    {
      "type": "header",
      "content": "Font sizes"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading — desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading — mobile",
      "default": 28
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text colour",
      "default": "#6b6864"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border colour",
      "default": "#ebe9e6"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star colour",
      "default": "#e0a32e"
    },
    {
      "type": "color",
      "id": "verified_color",
      "label": "Verified badge colour",
      "default": "#9b1f1f"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Review text",
          "default": "Absolutely brilliant product. Works instantly and leaves no smell whatsoever."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah T."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WipeOut Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review": "Saw results within minutes. No smell at all — sprayed the kitchen before bed and woke up to zero roaches.",
            "author": "Priya M.",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "review": "Used the termite spray on our skirting boards and old furniture. Three months on, still nothing. Brilliant.",
            "author": "David R.",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "review": "Finally something safe to use with a toddler and two cats in the house. The bed bug kit saved us.",
            "author": "Hannah K.",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
