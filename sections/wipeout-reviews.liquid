<style>
  #shopify-section-{{ section.id }} {
    --wo-rev-bg: {{ section.settings.bg_color }};
    --wo-rev-text: {{ section.settings.text_color }};
    --wo-rev-muted: {{ section.settings.muted_color }};
    --wo-rev-border: {{ section.settings.border_color }};
    --wo-rev-star: {{ section.settings.star_color }};
    --wo-rev-verified: {{ section.settings.verified_color }};
    --wo-rev-card-bg: {{ section.settings.card_bg_color }};
    --wo-rev-arrow-bg: {{ section.settings.arrow_bg_color }};
  }

  .wo-rev {
    background: var(--wo-rev-bg);
    color: var(--wo-rev-text);
  }

  .wo-rev__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  .wo-rev__heading {
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1;
    margin: 0 0 48px;
    text-align: center;
  }

  /* ── Carousel ── */
  .wo-rev__carousel {
    overflow: hidden;
  }

  .wo-rev__track {
    display: flex;
    gap: 24px;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Card ── */
  .wo-rev__card {
    flex: 0 0 350px;
    width: 350px;
    min-height: 270px;
    border: 1.5px solid var(--wo-rev-border);
    border-radius: 14px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--wo-rev-card-bg);
    box-sizing: border-box;
  }

  .wo-rev__card-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 18px;
    color: var(--wo-rev-star);
  }

  .wo-rev__author {
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 12px;
    color: var(--wo-rev-text);
  }

  .wo-rev__verified {
    color: var(--wo-rev-verified);
    font-weight: 600;
    font-size: 12px;
    margin-left: 5px;
  }

  .wo-rev__quote {
    font-size: 14px;
    line-height: 1.65;
    margin: 0;
    color: var(--wo-rev-muted);
  }

  /* ── Navigation ── */
  .wo-rev__nav {
    display: flex;
    gap: 14px;
    justify-content: center;
    margin-top: 36px;
  }

  .wo-rev__btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1.5px solid var(--wo-rev-border);
    background: var(--wo-rev-arrow-bg);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--wo-rev-text);
    transition: border-color 0.2s, opacity 0.2s;
    padding: 0;
  }

  .wo-rev__btn:hover {
    border-color: var(--wo-rev-text);
  }

  .wo-rev__btn:disabled {
    opacity: 0.3;
    cursor: default;
  }

  /* CSS chevron arrows */
  .wo-rev__btn::before {
    content: '';
    display: block;
    width: 9px;
    height: 9px;
    border-top: 2px solid currentColor;
    border-right: 2px solid currentColor;
  }

  .wo-rev__btn--prev::before {
    transform: rotate(-135deg) translate(-2px, 2px);
  }

  .wo-rev__btn--next::before {
    transform: rotate(45deg) translate(-2px, 2px);
  }

  /* ── Responsive ── */
  @media (max-width: 1023px) {
    .wo-rev__card {
      flex: 0 0 320px;
      width: 320px;
    }
  }

  @media (max-width: 767px) {
    .wo-rev__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: 30px;
    }

    .wo-rev__card {
      flex: 0 0 calc(100vw - 64px);
      width: calc(100vw - 64px);
      min-height: auto;
    }
  }
</style>

{%- assign star_svg = '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z"></path></svg>' -%}

<section class="wo-rev">
  <div class="wo-rev__inner">
    <h2 class="wo-rev__heading">{{ section.settings.heading }}</h2>

    <div class="wo-rev__carousel" id="wo-rev-carousel-{{ section.id }}">
      <div class="wo-rev__track" id="wo-rev-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="wo-rev__card" {{ block.shopify_attributes }}>
            <div class="wo-rev__card-stars">
              {%- for i in (1..block.settings.rating) -%}{{ star_svg }}{%- endfor -%}
            </div>
            <div class="wo-rev__author">
              {{ block.settings.author }}
              {%- if block.settings.verified -%}
                <span class="wo-rev__verified">&#10003; Verified</span>
              {%- endif -%}
            </div>
            <p class="wo-rev__quote">{{ block.settings.review }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="wo-rev__nav">
      <button class="wo-rev__btn wo-rev__btn--prev" id="wo-rev-prev-{{ section.id }}" aria-label="Previous reviews"></button>
      <button class="wo-rev__btn wo-rev__btn--next" id="wo-rev-next-{{ section.id }}" aria-label="Next reviews"></button>
    </div>
  </div>
</section>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var carousel = document.getElementById('wo-rev-carousel-' + sectionId);
    var track = document.getElementById('wo-rev-track-' + sectionId);
    var btnPrev = document.getElementById('wo-rev-prev-' + sectionId);
    var btnNext = document.getElementById('wo-rev-next-' + sectionId);
    if (!track || !btnPrev || !btnNext) return;

    var cards = track.querySelectorAll('.wo-rev__card');
    var current = 0;
    var timer = null;
    var speed = {{ section.settings.autoplay_speed | times: 1000 }};

    function gap() {
      return parseInt(window.getComputedStyle(track).gap) || 24;
    }

    function cardWidth() {
      return cards[0] ? cards[0].offsetWidth : 350;
    }

    function visible() {
      var cw = cardWidth();
      var g = gap();
      return Math.max(1, Math.floor((track.parentElement.offsetWidth + g) / (cw + g)));
    }

    function maxIndex() {
      return Math.max(0, cards.length - visible());
    }

    function goTo(index) {
      var max = maxIndex();
      current = index < 0 ? max : index > max ? 0 : index;
      track.style.transform = 'translateX(-' + (current * (cardWidth() + gap())) + 'px)';
    }

    function startAutoplay() {
      stopAutoplay();
      timer = setInterval(function () {
        goTo(current + 1);
      }, speed);
    }

    function stopAutoplay() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    btnPrev.addEventListener('click', function () {
      stopAutoplay(); goTo(current - 1); startAutoplay();
    });

    btnNext.addEventListener('click', function () {
      stopAutoplay(); goTo(current + 1); startAutoplay();
    });

    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);
    carousel.addEventListener('touchstart', stopAutoplay, { passive: true });
    carousel.addEventListener('touchend', startAutoplay, { passive: true });

    window.addEventListener('resize', function () {
      goTo(Math.min(current, maxIndex()));
    });

    goTo(0);
    startAutoplay();
  })();
</script>

