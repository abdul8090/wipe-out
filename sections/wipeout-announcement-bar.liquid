<style>
  #shopify-section-{{ section.id }} .wo-ann-bar {
    background: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    color: {{ section.settings.text_color }};
  }

  /* ── Desktop ── */
  #shopify-section-{{ section.id }} .wo-ann-bar__desktop {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__icon svg path,
  #shopify-section-{{ section.id }} .wo-ann-bar__icon svg circle,
  #shopify-section-{{ section.id }} .wo-ann-bar__icon svg rect {
    stroke: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__text {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__divider {
    width: 1px;
    height: 22px;
    background: {{ section.settings.border_color }};
    flex-shrink: 0;
  }

  /* ── Mobile slider ── */
  #shopify-section-{{ section.id }} .wo-ann-bar__mobile {
    display: none;
    align-items: center;
    padding: {{ section.settings.padding_y }}px 8px;
    position: relative;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__slider-wrap {
    flex: 1;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__track {
    display: flex;
    transition: transform 0.35s ease;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__slide {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__arrow {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.text_color }};
    flex-shrink: 0;
    border-radius: 50%;
    transition: background 0.2s;
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__arrow:hover {
    background: rgba(0,0,0,0.08);
  }

  #shopify-section-{{ section.id }} .wo-ann-bar__arrow svg path {
    stroke: {{ section.settings.text_color }};
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .wo-ann-bar__desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .wo-ann-bar__mobile {
      display: flex;
    }
  }
</style>

<div class="wo-ann-bar">

  {%- comment -%} Desktop: all badges in a row {%- endcomment -%}
  <div class="wo-ann-bar__desktop">
    {%- for block in section.blocks -%}
      {%- unless forloop.first -%}
        <div class="wo-ann-bar__divider"></div>
      {%- endunless -%}
      <div class="wo-ann-bar__item" {{ block.shopify_attributes }}>
        {%- if block.settings.badge_icon != blank -%}
          <div class="wo-ann-bar__icon">{{ block.settings.badge_icon }}</div>
        {%- endif -%}
        <span class="wo-ann-bar__text">{{ block.settings.badge_text }}</span>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} Mobile: auto-sliding single badge {%- endcomment -%}
  <div class="wo-ann-bar__mobile" id="wo-ann-mobile-{{ section.id }}">
    <button class="wo-ann-bar__arrow wo-ann-bar__arrow--prev" aria-label="Previous">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="wo-ann-bar__slider-wrap">
      <div class="wo-ann-bar__track" id="wo-ann-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="wo-ann-bar__slide" {{ block.shopify_attributes }}>
            {%- if block.settings.badge_icon != blank -%}
              <div class="wo-ann-bar__icon">{{ block.settings.badge_icon }}</div>
            {%- endif -%}
            <span class="wo-ann-bar__text">{{ block.settings.badge_text }}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
    <button class="wo-ann-bar__arrow wo-ann-bar__arrow--next" aria-label="Next">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

</div>

<script>
  (function () {
    var id = '{{ section.id }}';
    var wrap = document.getElementById('wo-ann-mobile-' + id);
    var track = document.getElementById('wo-ann-track-' + id);
    if (!wrap || !track) return;

    var slides = track.querySelectorAll('.wo-ann-bar__slide');
    var total = slides.length;
    var current = 0;
    var timer = null;
    var speed = {{ section.settings.autoplay_speed | times: 1000 }};

    function setWidths() {
      var w = track.parentElement.offsetWidth;
      slides.forEach(function (s) { s.style.width = w + 'px'; });
    }

    function goTo(index) {
      current = ((index % total) + total) % total;
      track.style.transform = 'translateX(-' + (current * slides[0].offsetWidth) + 'px)';
    }

    function startAuto() {
      stopAuto();
      timer = setInterval(function () { goTo(current + 1); }, speed);
    }

    function stopAuto() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    wrap.querySelector('.wo-ann-bar__arrow--prev').addEventListener('click', function () {
      stopAuto(); goTo(current - 1); startAuto();
    });

    wrap.querySelector('.wo-ann-bar__arrow--next').addEventListener('click', function () {
      stopAuto(); goTo(current + 1); startAuto();
    });

    wrap.addEventListener('mouseenter', stopAuto);
    wrap.addEventListener('mouseleave', startAuto);

    window.addEventListener('resize', function () { setWidths(); goTo(current); });

    setWidths();
    goTo(0);
    startAuto();
  })();
</script>

{% schema %}
{
  "name": "WipeOut Announcement Bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Mobile auto-slide speed",
      "default": 3
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_y",
