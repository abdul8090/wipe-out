<style>
  /* CSS custom properties */
  #shopify-section-{{ section.id }} {
    --faq-bg:         {{ section.settings.background_color }};
    --faq-border:     {{ section.settings.border_color }};
    --faq-subtitle:   {{ section.settings.subtitle_color }};
    --faq-heading:    {{ section.settings.heading_color }};
    --faq-desc:       {{ section.settings.description_color }};
    --faq-item-bg:    {{ section.settings.faq_background }};
    --faq-active-bg:  {{ section.settings.faq_active_background }};
    --faq-toggle-bg:  {{ section.settings.toggle_bg }};
    background-color: var(--faq-bg);
    border-bottom: 1px solid var(--faq-border);
  }

  /* Container */
  #shopify-section-{{ section.id }} .wo-faq_container {
    max-width: 1280px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  /* Layout */
  #shopify-section-{{ section.id }} .wo-faq_wrapper {
    display: flex;
    gap: 40px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .wo-faq_wrapper.hide-image {
    display: block;
  }

  #shopify-section-{{ section.id }} .wo-faq_wrapper.hide-image .wo-faq_header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .wo-faq_wrapper.hide-image .wo-faq_items-wrap {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Image column */
  #shopify-section-{{ section.id }} .wo-faq_image {
    flex: 0 0 50%;
  }

  #shopify-section-{{ section.id }} .wo-faq_img {
    width: 100%;
    height: 630px;
    border-radius: 16px;
    object-fit: cover;
  }

  /* Content column */
  #shopify-section-{{ section.id }} .wo-faq_content {
    flex: 1;
  }

  #shopify-section-{{ section.id }} .wo-faq_header {
    margin-bottom: 30px;
    text-align: left;
  }

  #shopify-section-{{ section.id }} .wo-faq_subtitle {
    color: var(--faq-subtitle);
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: 700;
    line-height: 150%;
    margin: 0 0 4px;
  }

  #shopify-section-{{ section.id }} .wo-faq_heading {
    color: var(--faq-heading);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    line-height: 120%;
    margin: 0 0 20px;
  }

  #shopify-section-{{ section.id }} .wo-faq_description {
    color: var(--faq-desc);
    font-size: {{ section.settings.description_size }}px;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
  }

  /* FAQ items */
  #shopify-section-{{ section.id }} .wo-faq_items {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 30px;
  }

  #shopify-section-{{ section.id }} .wo-faq_item {
    border-radius: 16px;
    border: 1px solid var(--faq-border);
    background: var(--faq-item-bg);
    box-shadow: 0px 4px 0px -2px var(--faq-border);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .wo-faq_question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .wo-faq_question[data-open="true"] {
    border-bottom: 1px dashed var(--faq-border);
    background: var(--faq-active-bg);
  }

  #shopify-section-{{ section.id }} .wo-faq_question span {
    font-size: {{ section.settings.question_size }}px;
    font-weight: 600;
    line-height: 1.5;
    color: var(--faq-heading);
  }

  #shopify-section-{{ section.id }} .wo-faq_toggle-btn {
    flex-shrink: 0;
    background: var(--faq-toggle-bg);
    border: 1px solid var(--faq-border);
    border-radius: 999px;
    padding: 5px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--faq-border);
  }

  #shopify-section-{{ section.id }} .wo-faq_toggle-btn svg path {
    stroke: currentColor;
  }

  #shopify-section-{{ section.id }} .wo-faq_answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  #shopify-section-{{ section.id }} .wo-faq_answer[data-open="true"] {
    background: var(--faq-active-bg);
  }

  #shopify-section-{{ section.id }} .wo-faq_answer p {
    margin: 0;
    font-size: {{ section.settings.answer_size }}px;
    line-height: 150%;
    color: var(--faq-desc);
    padding: 10px 20px 16px;
  }

  /* Tablet */
  @media (max-width: 992px) {
    #shopify-section-{{ section.id }} .wo-faq_wrapper {
      flex-direction: column;
      gap: 0;
    }

    #shopify-section-{{ section.id }} .wo-faq_image {
      flex: 0 0 100%;
      width: 100%;
      max-width: 400px;
      margin: 0 auto 40px;
    }

    #shopify-section-{{ section.id }} .wo-faq_img {
      height: auto;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .wo-faq_container {
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .wo-faq_wrapper.hide-image .wo-faq_items-wrap {
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .wo-faq_header {
      text-align: center;
    }

    #shopify-section-{{ section.id }} .wo-faq_subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .wo-faq_heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .wo-faq_description {
      font-size: {{ section.settings.description_size_mobile }}px;
      margin-bottom: 20px;
    }

    #shopify-section-{{ section.id }} .wo-faq_question span {
      font-size: {{ section.settings.question_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .wo-faq_answer p {
      font-size: {{ section.settings.answer_size_mobile }}px;
    }
  }
</style>

<div class="wo-faq_container">
  <div class="wo-faq_wrapper{% if section.settings.hide_image %} hide-image{% endif %}">

    {%- unless section.settings.hide_image -%}
      <div class="wo-faq_image">
        {%- if section.settings.faq_image != blank -%}
          {%- assign faq_img_alt = section.settings.heading | escape -%}
          {{
            section.settings.faq_image
            | image_url: width: 800
            | image_tag: class: 'wo-faq_img', alt: faq_img_alt, loading: 'lazy', widths: '400, 600, 800'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'wo-faq_img placeholder' }}
        {%- endif -%}
      </div>
    {%- endunless -%}

    <div class="wo-faq_content">
      <div class="wo-faq_header">
        {%- if section.settings.subtitle != blank -%}
          <p class="wo-faq_subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="wo-faq_heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="wo-faq_description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      <div class="wo-faq_items-wrap">
        <div class="wo-faq_items">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq_item' -%}
              {%- assign is_open = block.settings.open_by_default -%}
              <div class="wo-faq_item" {{ block.shopify_attributes }}>
                <div
                  class="wo-faq_question"
                  data-open="{% if is_open %}true{% else %}false{% endif %}"
                >
                  <span>{{ block.settings.question }}</span>
                  <button class="wo-faq_toggle-btn" aria-label="Toggle answer">
                    {%- if is_open -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3.3335 8.00004H12.6668" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {%- else -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3.3335 8.00004H12.6668M8.00016 3.33337V12.6667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {%- endif -%}
                  </button>
                </div>
                <div
                  class="wo-faq_answer"
                  data-open="{% if is_open %}true{% else %}false{% endif %}"
                  {%- if is_open %} style="max-height: 1000px;"{%- endif -%}
                >
                  <p>{{ block.settings.answer }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  var section = document.querySelector('#shopify-section-{{ section.id }}');
  if (!section) return;

  var faqItems = section.querySelectorAll('.wo-faq_item');

  var PLUS_SVG  = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3.3335 8.00004H12.6668M8.00016 3.33337V12.6667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  var MINUS_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3.3335 8.00004H12.6668" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  faqItems.forEach(function (item) {
    var question  = item.querySelector('.wo-faq_question');
    var answer    = item.querySelector('.wo-faq_answer');
    var toggleBtn = item.querySelector('.wo-faq_toggle-btn');

    if (!question || !answer) return;

    /* Set correct initial height for items open by default */
    if (question.getAttribute('data-open') === 'true') {
      answer.style.maxHeight = answer.scrollHeight + 'px';
    }

    question.addEventListener('click', function () {
      var isOpen = question.getAttribute('data-open') === 'true';

      /* Close all other items */
      faqItems.forEach(function (other) {
        if (other === item) return;
        var oQ = other.querySelector('.wo-faq_question');
        var oA = other.querySelector('.wo-faq_answer');
        var oT = other.querySelector('.wo-faq_toggle-btn');
        if (!oQ || !oA) return;
        oQ.setAttribute('data-open', 'false');
        oA.setAttribute('data-open', 'false');
        oA.style.maxHeight = '0';
        if (oT) oT.innerHTML = PLUS_SVG;
      });

      /* Toggle this item */
      if (isOpen) {
        question.setAttribute('data-open', 'false');
        answer.setAttribute('data-open', 'false');
        answer.style.maxHeight = '0';
        if (toggleBtn) toggleBtn.innerHTML = PLUS_SVG;
      } else {
        question.setAttribute('data-open', 'true');
        answer.setAttribute('data-open', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        if (toggleBtn) toggleBtn.innerHTML = MINUS_SVG;
      }
    });
  });
})();
</script>

