<div
  class="maison_commerce_product_benefits"
  style="background-color: {{ section.settings.section_bg_color }};"
  id="ProductBenefitTabs-{{ section.id }}"
>
  <div class="maison_commerce_container">
    <div class="maison_commerce_header">
      {% if section.settings.title != blank %}
        <h2 class="maison_commerce_title" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.title }}
        </h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="maison_commerce_subtitle" style="color: {{ section.settings.text_color }};">
          {{ section.settings.subtitle }}
        </p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="maison_commerce_product_nav_container">
        <div
          class="maison_commerce_product_nav_wrapper"
          style="scrollbar-width: none; overflow-x: auto; border-radius: 999px;"
        >
          <div class="maison_commerce_product_nav">
            {% for block in section.blocks %}
              {% if block.type == 'product_tab' %}
                <button
                  class="maison_commerce_nav_item {% if forloop.first %}maison_commerce_active{% endif %}"
                  data-tab="{{ block.id }}"
                  data-active-bg="{{ section.settings.nav_active_bg }}"
                  style="color: {{ section.settings.heading_color }};"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.tab_name }}
                </button>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="maison_commerce_content_container">
        {% for block in section.blocks %}
          {% if block.type == 'product_tab' %}
            <div
              class="maison_commerce_content {% if forloop.first %}maison_commerce_content_active{% endif %}"
              data-content="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="maison_commerce_product_image">
                {% if block.settings.product_image != blank %}
                  {{
                    block.settings.product_image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', alt: block.settings.tab_name
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>

              <div
                class="maison_commerce_ingredients_grid"
                style="grid-template-columns: repeat({{ block.settings.grid_columns }}, 1fr);"
              >
                {% for i in (1..8) %}
                  {% assign ingredient_image = 'ingredient_image_' | append: i %}
                  {% assign ingredient_title = 'ingredient_title_' | append: i %}
                  {% assign ingredient_description = 'ingredient_description_' | append: i %}
                  {% assign ingredient_tag = 'ingredient_tag_' | append: i %}

                  {% if block.settings[ingredient_title] != blank %}
                    <div class="maison_commerce_ingredient_item">
                      <div class="maison_commerce_ingredient_image">
                        {% if block.settings[ingredient_image] != blank %}
                          {{
                            block.settings[ingredient_image]
                            | image_url: width: 70
                            | image_tag: loading: 'lazy', alt: block.settings[ingredient_title]
                          }}
                        {% else %}
                          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </div>
                      <div class="maison_commerce_ingredient_content">
                        <h3
                          class="maison_commerce_ingredient_title"
                          style="color: {{ section.settings.heading_color }};"
                        >
                          {{ block.settings[ingredient_title] }}
                        </h3>
                        <p
                          class="maison_commerce_ingredient_description"
                          style="color: {{ section.settings.text_color }};"
                        >
                          {{ block.settings[ingredient_description] }}
                        </p>
                        {% if block.settings[ingredient_tag] != blank and section.settings.hide_benefit_tags != true %}
                          <span
                            class="maison_commerce_benefit_tag"
                            style="background-color: {{ section.settings.tag_bg_color }}; color: {{ section.settings.tag_text_color }}; border-color: {{ section.settings.heading_color }};"
                          >
                            {{ block.settings[ingredient_tag] }}
                          </span>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  @font-face {
    font-family: "Gt America Trial";
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Regular-Trial.woff2?v=1745508413') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Gt America Trial";
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Regular-Italic-Trial.woff2?v=1745508412') format('woff2');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Gt America Trial";
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Medium-Trial.woff2?v=1745508412') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Gt America Trial";
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Bold-Trial.woff2?v=1745508413') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: Organetto Variable --Trial;
    src: url('{{ "Fontspring-Organetto.otf" | asset_url }}');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  .maison_commerce_product_benefits {
    padding: 60px 20px;
    width: 100%;
    font-family: {{ settings.type_body_font_family }};
  }

  .maison_commerce_container {
    max-width: 1200px;
    margin: 0 auto;
    {% comment %} padding: 0 20px; {% endcomment %}
  }

  .maison_commerce_header {
    text-align: center;
    margin-bottom: 32px;
  }

  .maison_commerce_title {
    font-family: Organetto-Variable;
    font-size: 48px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .maison_commerce_subtitle {
    font-family: "GT America Trial";
    font-size: 18px;
    line-height: 1.5;
    max-width: 720px;
    margin: 0 auto;
  }

  .maison_commerce_product_nav_container {
    margin: 0 auto 40px;
    max-width: 800px;
    width: fit-content;
    background: #FFFFFF;
    border: 1px solid #000;
    border-radius: 40px;
    padding: 5px;
    overflow: hidden;
  }

  .maison_commerce_product_nav {
    display: flex;
    justify-content: center;
  }

  .maison_commerce_nav_item {
    background: transparent;
    border: none;
    padding: 8px 16px;
    font-family: "GT America Trial";
    font-size: 16px;
    font-weight: 700;
    line-height: 150%;
    color: #2C2609;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 40px;
    white-space: nowrap;
  }

  .maison_commerce_nav_item.maison_commerce_active {
    border: 1px solid #000;
    font-weight: 600;
  }

  .maison_commerce_content {
    display: none;
    flex-wrap: wrap;
    gap: 40px;
    align-items: center;
  }

  .maison_commerce_content.maison_commerce_content_active {
    display: flex;
  }

  .maison_commerce_product_image {
    flex: 1;
    min-width: 300px;
    max-width: 450px;
  }

  .maison_commerce_product_image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 2px solid #fff;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }

  .maison_commerce_ingredients_grid {
    flex: 1;
    min-width: 300px;
    display: grid;
    grid-gap: 10px;
  }

  .maison_commerce_ingredient_item {
    display: flex;
    gap: 15px;
    background: white;
    border: 1px solid black;
    border-radius: 10px;
    align-items: center;
    padding: 16px;
  }

  .maison_commerce_ingredient_image {
    width: 96px;
    height: 96px;
    flex-shrink: 0;
    background: #EFEFEF;
  }

  .maison_commerce_ingredient_image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .maison_commerce_ingredient_content {
    flex-grow: 1;
  }

  .maison_commerce_ingredient_title {
    font-family: "GT America Trial" !important;
    font-size: 18px;
    font-weight: 700;
    line-height: 150%;
    color: #1D211E;
    margin: 0 0 8px;
    text-transform: none;
  }

  .maison_commerce_ingredient_description {
    font-size: 14px;
    margin: 0 0 10px;
    line-height: 1.4;
  }

  .maison_commerce_benefit_tag {
    display: inline-block;
    border: 1px solid;
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 16px;
    font-weight: 700;
  }

  @media (max-width: 991px) {
    .maison_commerce_product_nav_container {
      max-width: 100%;
    }

    .maison_commerce_content {
      flex-direction: column;
    }

    .maison_commerce_product_image {
      max-width: 100%;
      order: 2;
    }

    .maison_commerce_ingredients_grid {
      order: 1;
    }
  }

  @media (max-width: 767px) {
    .maison_commerce_product_benefits {
      padding: 20px 16px 40px;
    }

    .maison_commerce_ingredients_grid {
      grid-template-columns: 1fr !important;
      gap: 0px;
    }

    .maison_commerce_title {
      font-family: Organetto-Variable;
      font-size: 36px;
      margin-bottom: 24px;
    }

    .maison_commerce_subtitle {
      font-family: "GT America Trial";
      font-size: 14px;
      padding: 0 20px;
    }

    .maison_commerce_product_nav_container {
      {% comment %} width: 100%; {% endcomment %}
      margin-bottom: 30px;
      {% comment %} overflow-x: auto; {% endcomment %}
      -ms-overflow-style: none;
      scrollbar-width: none;
      padding: 0px;
    }

    .maison_commerce_product_nav_container::-webkit-scrollbar {
      display: none;
    }

    .maison_commerce_product_nav {
      width: max-content;
      justify-content: flex-start;
      padding: 0px;
    }

    .maison_commerce_nav_item {
      padding: 10px 15px;
      font-size: 14px;
      margin: 2px;
      flex-shrink: 0;
    }

    .maison_commerce_ingredient_item {
      margin-bottom: 16px;
      padding: 10px;
    }

    .maison_commerce_ingredient_image {
      width: 72px;
      height: 72px;
    }

    .maison_commerce_ingredient_title {
      font-size: 14px;
    }

    .maison_commerce_ingredient_description {
      font-size: 14px;
    }

    .maison_commerce_benefit_tag {
      font-size: 12px;
    }
  }
</style>

<script>
  (function () {
    const sectionId = 'ProductBenefitTabs-{{ section.id }}';
    const section = document.getElementById(sectionId);

    if (!section) return;

    const navItems = section.querySelectorAll('.maison_commerce_nav_item');
    const navContainer = section.querySelector('.maison_commerce_product_nav_container');
    const contentItems = section.querySelectorAll('.maison_commerce_content');

    navItems.forEach((item) => {
      item.addEventListener('click', function () {
        // Remove active class from all nav items
        navItems.forEach((navItem) => {
          navItem.classList.remove('maison_commerce_active');
          navItem.style.backgroundColor = 'transparent';
        });

        // Add active class to clicked item
        this.classList.add('maison_commerce_active');
        this.style.backgroundColor = this.getAttribute('data-active-bg');

        // Show the corresponding content tab
        const tabContent = this.getAttribute('data-tab');

        // Hide all content sections
        contentItems.forEach((content) => {
          content.classList.remove('maison_commerce_content_active');
        });

        // Show the selected content section
        section
          .querySelector(`.maison_commerce_content[data-content="${tabContent}"]`)
          .classList.add('maison_commerce_content_active');

        // Scroll the container to show the active button
        if (window.innerWidth <= 767) {
          const buttonRect = this.getBoundingClientRect();
          const containerRect = navContainer.getBoundingClientRect();

          // Calculate the scroll amount to center the button in the container
          const scrollLeft = this.offsetLeft - containerRect.width / 2 + buttonRect.width / 2;

          // Smooth scroll to the position
          navContainer.scrollTo({
            left: scrollLeft,
            behavior: 'smooth',
          });
        }
      });
    });

    // Set initial active tab background color
    const activeTab = section.querySelector('.maison_commerce_nav_item.maison_commerce_active');
    if (activeTab) {
      activeTab.style.backgroundColor = activeTab.getAttribute('data-active-bg');
    }
  })();
</script>
