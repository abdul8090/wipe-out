<style>
  #shopify-section-{{ section.id }} {
    --wo-hero-bg: {{ section.settings.bg_color }};
    --wo-hero-height: {{ section.settings.slide_height }}px;
  }

  .wo-hero {
    position: relative;
    background: var(--wo-hero-bg);
    overflow: hidden;
  }

  .wo-hero__track-wrap {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .wo-hero__track {
    display: flex;
    width: 100%;
    transition: transform 0.7s cubic-bezier(0.7, 0, 0.2, 1);
  }

  .wo-hero__slide {
    flex: 0 0 100%;
    height: var(--wo-hero-height);
    position: relative;
    display: block;
    text-decoration: none;
  }

  .wo-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wo-hero__slide-link {
    display: block;
    height: 100%;
  }

  .wo-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    padding: 0 clamp(24px, 5vw, 80px);
    pointer-events: none;
  }

  .wo-hero__overlay-inner {
    max-width: 560px;
    pointer-events: all;
  }

  .wo-hero__eyebrow {
    font-size: 12.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 14px;
  }

  .wo-hero__heading {
    font-family: 'Assistant', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    font-size: clamp(32px, 5vw, 68px);
    line-height: 0.95;
    margin: 0 0 16px;
  }

  .wo-hero__sub {
    font-size: 16px;
    line-height: 1.5;
    margin: 0 0 28px;
    max-width: 440px;
  }

  .wo-hero__btn {
    display: inline-block;
    border: none;
    border-radius: 4px;
    padding: 15px 34px;
    font-weight: 700;
    font-size: 15px;
    font-family: inherit;
    cursor: pointer;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .wo-hero__btn:hover {
    opacity: 0.88;
  }

  .wo-hero__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid #e6e2dd;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #181512;
    z-index: 2;
    transition: background 0.2s;
  }

  .wo-hero__arrow:hover {
    background: #fff;
  }

  .wo-hero__arrow--prev {
    left: 18px;
  }

  .wo-hero__arrow--next {
    right: 18px;
  }

  .wo-hero__dots {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    align-items: center;
    z-index: 2;
  }

  .wo-hero__dot {
    height: 9px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    padding: 0;
    transition: all 0.4s;
    background: rgba(24, 21, 18, 0.25);
    width: 9px;
  }

  .wo-hero__dot.is-active {
    width: 24px;
    background: #181512;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --wo-hero-height: {{ section.settings.slide_height | times: 0.65 | round }}px;
    }

    .wo-hero__arrow {
      width: 36px;
      height: 36px;
    }

    .wo-hero__arrow--prev {
      left: 10px;
    }

    .wo-hero__arrow--next {
      right: 10px;
    }
  }

  @media (max-width: 480px) {
    #shopify-section-{{ section.id }} {
      --wo-hero-height: {{ section.settings.slide_height | times: 0.5 | round }}px;
    }
  }
</style>

{%- assign section_id = 'wo-hero-' | append: section.id -%}

<section class="wo-hero">
  <div class="wo-hero__track-wrap">
    <div class="wo-hero__track" id="{{ section_id }}-track">
      {%- for block in section.blocks -%}
        <div class="wo-hero__slide" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {%- assign slide_alt = block.settings.image.alt | escape -%}
            {%- assign slide_loading = 'lazy' -%}
            {%- if forloop.first -%}{%- assign slide_loading = 'eager' -%}{%- endif -%}
            {%- if block.settings.link != blank -%}
              <a class="wo-hero__slide-link" href="{{ block.settings.link }}">
            {%- endif -%}
            {{
              block.settings.image
              | image_url: width: 1600
              | image_tag:
                alt: slide_alt,
                loading: slide_loading,
                widths: '480, 768, 1024, 1280, 1600'
            }}
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          {%- else -%}
            {%- style -%}
              #{{ section_id }}-slide-{{ forloop.index }} { background: {{ block.settings.slide_bg_color }}; }
            {%- endstyle -%}
            <div id="{{ section_id }}-slide-{{ forloop.index }}" style="width:100%;height:100%">
              {%- if block.settings.link != blank -%}
                <a class="wo-hero__slide-link" href="{{ block.settings.link }}"></a>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
            {%- style -%}
              #{{ section_id }}-overlay-{{ forloop.index }} .wo-hero__eyebrow { color: {{ block.settings.eyebrow_color }}; }
              #{{ section_id }}-overlay-{{ forloop.index }} .wo-hero__heading { color: {{ block.settings.heading_color }}; }
              #{{ section_id }}-overlay-{{ forloop.index }} .wo-hero__sub { color: {{ block.settings.subheading_color }}; }
              #{{ section_id }}-overlay-{{ forloop.index }} .wo-hero__btn { background: {{ block.settings.button_bg }}; color: {{ block.settings.button_text_color }}; }
            {%- endstyle -%}
            <div class="wo-hero__overlay" id="{{ section_id }}-overlay-{{ forloop.index }}">
              <div class="wo-hero__overlay-inner">
                {%- if block.settings.eyebrow != blank -%}
                  <div class="wo-hero__eyebrow">{{ block.settings.eyebrow }}</div>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="wo-hero__heading">{{ block.settings.heading }}</h2>
                {%- endif -%}
                {%- if block.settings.subheading != blank -%}
                  <p class="wo-hero__sub">{{ block.settings.subheading }}</p>
                {%- endif -%}
                {%- if block.settings.button_label != blank and block.settings.link != blank -%}
                  <a class="wo-hero__btn" href="{{ block.settings.link }}">{{ block.settings.button_label }}</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button class="wo-hero__arrow wo-hero__arrow--prev" id="{{ section_id }}-prev" aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"></path></svg>
      </button>
      <button class="wo-hero__arrow wo-hero__arrow--next" id="{{ section_id }}-next" aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>
      </button>
      <div class="wo-hero__dots" id="{{ section_id }}-dots">
        {%- for block in section.blocks -%}
          <button class="wo-hero__dot{% if forloop.first %} is-active{% endif %}" aria-label="Go to slide {{ forloop.index }}" data-index="{{ forloop.index0 }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
(function () {
  var id = '{{ section_id }}';
  var track = document.getElementById(id + '-track');
  if (!track) return;

  var slides = track.querySelectorAll('.wo-hero__slide');
  var dotsWrap = document.getElementById(id + '-dots');
  var dots = dotsWrap ? dotsWrap.querySelectorAll('.wo-hero__dot') : [];
  var total = slides.length;
  var current = 0;

  function goTo(n) {
    current = (n + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function (d, i) {
      d.classList.toggle('is-active', i === current);
    });
  }

  var prev = document.getElementById(id + '-prev');
  var next = document.getElementById(id + '-next');
  if (prev) prev.addEventListener('click', function () { goTo(current - 1); });
  if (next) next.addEventListener('click', function () { goTo(current + 1); });
  dots.forEach(function (d) {
    d.addEventListener('click', function () { goTo(parseInt(d.dataset.index)); });
  });

  {% if section.settings.autoplay and section.blocks.size > 1 %}
  setInterval(function () { goTo(current + 1); }, {{ section.settings.autoplay_speed | times: 1000 }});
  {% endif %}
})();
</script>

{% schema %}
{
  "name": "WipeOut Hero Carousel",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "slide_height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Slide height",
      "default": 540
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Rotation speed",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "color",
          "id": "slide_bg_color",
          "label": "Slide background colour (if no image)",
          "default": "#fdf4f3"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide link"
        },
        {
          "type": "header",
          "content": "Overlay text (optional)"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text"
        },
        {
          "type": "color",
          "id": "eyebrow_color",
          "label": "Eyebrow colour",
          "default": "#9b1f1f"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading colour",
          "default": "#181512"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "color",
          "id": "subheading_color",
          "label": "Subheading colour",
          "default": "#6b6864"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "color",
          "id": "button_bg",
          "label": "Button background",
          "default": "#9b1f1f"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text colour",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WipeOut Hero Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
