<style>
  @font-face {
    font-family: 'Assistant', sans-serif;
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Regular-Trial.woff2?v=1745508413') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Assistant', sans-serif;
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Regular-Italic-Trial.woff2?v=1745508412') format('woff2');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: 'Assistant', sans-serif;
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Medium-Trial.woff2?v=1745508412') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Assistant', sans-serif;
    src: url('https://cdn.shopify.com/s/files/1/0638/8383/7620/files/GT-America-Standard-Bold-Trial.woff2?v=1745508413') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  /* CSS custom properties — all controlled from section settings */
  #shopify-section-{{ section.id }} {
    --tc-bg:          {{ section.settings.section_bg_color }};
    --tc-heading:     {{ section.settings.heading_color }};
    --tc-text:        {{ section.settings.text_color }};
    --tc-nav-bg:      {{ section.settings.nav_bg }};
    --tc-nav-border:  {{ section.settings.nav_border }};
    --tc-nav-text:    {{ section.settings.nav_text }};
    --tc-nav-active:  {{ section.settings.nav_active_bg }};
    --tc-card-bg:     {{ section.settings.card_bg }};
    --tc-card-border: {{ section.settings.card_border }};
    --tc-img-bg:      {{ section.settings.ingredient_img_bg }};
    --tc-tag-bg:      {{ section.settings.tag_bg_color }};
    --tc-tag-text:    {{ section.settings.tag_text_color }};
    --tc-tag-border:  {{ section.settings.heading_color }};
  }

  /* Section wrapper */
  #shopify-section-{{ section.id }} .tc-section {
    background-color: var(--tc-bg);
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    width: 100%;
    font-family: 'Assistant', sans-serif;
  }

  #shopify-section-{{ section.id }} .tc-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  #shopify-section-{{ section.id }} .tc-header {
    text-align: center;
    margin-bottom: 32px;
  }

  #shopify-section-{{ section.id }} .tc-title {
    font-family: 'Assistant', sans-serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--tc-heading);
    margin: 0 0 16px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .tc-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    line-height: 1.5;
    color: var(--tc-text);
    max-width: 720px;
    margin: 0 auto;
  }

  /* Tab nav */
  #shopify-section-{{ section.id }} .tc-nav-container {
    margin: 0 auto 40px;
    max-width: 800px;
    width: fit-content;
    background: var(--tc-nav-bg);
    border: 1px solid var(--tc-nav-border);
    border-radius: 40px;
    padding: 5px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .tc-nav-wrapper {
    overflow-x: auto;
    scrollbar-width: none;
    border-radius: 999px;
  }

  #shopify-section-{{ section.id }} .tc-nav-wrapper::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .tc-nav {
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .tc-nav-btn {
    background: transparent;
    border: none;
    padding: 8px 16px;
    font-family: 'Assistant', sans-serif;
    font-size: {{ section.settings.nav_size }}px;
    font-weight: 700;
    line-height: 1.5;
    color: var(--tc-nav-text);
    cursor: pointer;
    transition: background-color 0.3s ease;
    border-radius: 40px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .tc-nav-btn.tc-active {
    background-color: var(--tc-nav-active);
    border: 1px solid var(--tc-nav-border);
    font-weight: 600;
  }

  /* Tab content */
  #shopify-section-{{ section.id }} .tc-content {
    display: none;
    flex-wrap: wrap;
    gap: 40px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .tc-content.tc-content-active {
    display: flex;
  }

  /* Product image */
  #shopify-section-{{ section.id }} .tc-product-image {
    flex: 1;
    min-width: 300px;
    max-width: 450px;
  }

  #shopify-section-{{ section.id }} .tc-product-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 2px solid var(--tc-nav-bg);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  /* Ingredients grid */
  #shopify-section-{{ section.id }} .tc-grid {
    flex: 1;
    min-width: 300px;
    display: grid;
    grid-gap: 10px;
  }

  #shopify-section-{{ section.id }} .tc-ingredient {
    display: flex;
    gap: 15px;
    background: var(--tc-card-bg);
    border: 1px solid var(--tc-card-border);
    border-radius: 10px;
    align-items: center;
    padding: 16px;
  }

  #shopify-section-{{ section.id }} .tc-ingredient-img {
    width: 96px;
    height: 96px;
    flex-shrink: 0;
    background: var(--tc-img-bg);
    border-radius: 6px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .tc-ingredient-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .tc-ingredient-body {
    flex-grow: 1;
  }

  #shopify-section-{{ section.id }} .tc-ingredient-title {
    font-family: 'Assistant', sans-serif;
    font-size: {{ section.settings.ingredient_title_size }}px;
    font-weight: 700;
    line-height: 1.5;
    color: var(--tc-heading);
    margin: 0 0 8px;
    text-transform: none;
  }

  #shopify-section-{{ section.id }} .tc-ingredient-desc {
    font-size: {{ section.settings.ingredient_desc_size }}px;
    color: var(--tc-text);
    margin: 0 0 10px;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .tc-tag {
    display: inline-block;
    background-color: var(--tc-tag-bg);
    color: var(--tc-tag-text);
    border: 1px solid var(--tc-tag-border);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: {{ section.settings.tag_size }}px;
    font-weight: 700;
  }

  /* Tablet */
  @media (max-width: 991px) {
    #shopify-section-{{ section.id }} .tc-nav-container {
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .tc-content {
      flex-direction: column;
    }

    #shopify-section-{{ section.id }} .tc-product-image {
      max-width: 100%;
      order: 2;
    }

    #shopify-section-{{ section.id }} .tc-grid {
      order: 1;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .tc-section {
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .tc-title {
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .tc-subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .tc-nav-container {
      margin-bottom: 30px;
      -ms-overflow-style: none;
      scrollbar-width: none;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .tc-nav {
      width: max-content;
      justify-content: flex-start;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .tc-nav-btn {
      padding: 10px 15px;
      font-size: {{ section.settings.nav_size_mobile }}px;
      margin: 2px;
      flex-shrink: 0;
    }

    #shopify-section-{{ section.id }} .tc-grid {
      grid-template-columns: 1fr !important;
      gap: 0;
    }

    #shopify-section-{{ section.id }} .tc-ingredient {
      margin-bottom: 16px;
      padding: 10px;
    }

    #shopify-section-{{ section.id }} .tc-ingredient-img {
      width: 72px;
      height: 72px;
    }

    #shopify-section-{{ section.id }} .tc-ingredient-title {
      font-size: {{ section.settings.ingredient_title_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .tc-ingredient-desc {
      font-size: {{ section.settings.ingredient_desc_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .tc-tag {
      font-size: {{ section.settings.tag_size_mobile }}px;
    }
  }
</style>

<div class="tc-section" id="ProductBenefitTabs-{{ section.id }}">
  <div class="tc-container">

    <div class="tc-header">
      {%- if section.settings.title != blank -%}
        <h2 class="tc-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="tc-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="tc-nav-container">
        <div class="tc-nav-wrapper">
          <div class="tc-nav">
            {%- for block in section.blocks -%}
              {%- if block.type == 'product_tab' -%}
                <button
                  class="tc-nav-btn{% if forloop.first %} tc-active{% endif %}"
                  data-tab="{{ block.id }}"
                  {{ block.shopify_attributes }}
                >{{ block.settings.tab_name }}</button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      <div class="tc-content-container">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_tab' -%}
            <div
              class="tc-content{% if forloop.first %} tc-content-active{% endif %}"
              data-content="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="tc-product-image">
                {%- if block.settings.product_image != blank -%}
                  {%- assign tab_alt = block.settings.tab_name | escape -%}
                  {{
                    block.settings.product_image
                    | image_url: width: 900
                    | image_tag: loading: 'lazy', alt: tab_alt, widths: '400, 600, 900'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              <div class="tc-grid" style="grid-template-columns: repeat({{ block.settings.grid_columns }}, 1fr);">
                {%- for i in (1..8) -%}
                  {%- assign ing_image_key = 'ingredient_image_' | append: i -%}
                  {%- assign ing_title_key = 'ingredient_title_' | append: i -%}
                  {%- assign ing_desc_key  = 'ingredient_description_' | append: i -%}
                  {%- assign ing_tag_key   = 'ingredient_tag_' | append: i -%}

                  {%- if block.settings[ing_title_key] != blank -%}
                    <div class="tc-ingredient">
                      <div class="tc-ingredient-img">
                        {%- if block.settings[ing_image_key] != blank -%}
                          {%- assign ing_alt = block.settings[ing_title_key] | escape -%}
                          {{
                            block.settings[ing_image_key]
                            | image_url: width: 192
                            | image_tag: loading: 'lazy', alt: ing_alt, widths: '96, 144, 192'
                          }}
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                        {%- endif -%}
                      </div>
                      <div class="tc-ingredient-body">
                        <h3 class="tc-ingredient-title">{{ block.settings[ing_title_key] }}</h3>
                        <p class="tc-ingredient-desc">{{ block.settings[ing_desc_key] }}</p>
                        {%- if block.settings[ing_tag_key] != blank and section.settings.hide_benefit_tags != true -%}
                          <span class="tc-tag">{{ block.settings[ing_tag_key] }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script>
(function () {
  var section = document.getElementById('ProductBenefitTabs-{{ section.id }}');
  if (!section) return;

  var navBtns    = section.querySelectorAll('.tc-nav-btn');
  var navWrapper = section.querySelector('.tc-nav-wrapper');
  var contents   = section.querySelectorAll('.tc-content');

  navBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      navBtns.forEach(function (b) { b.classList.remove('tc-active'); });
      contents.forEach(function (c) { c.classList.remove('tc-content-active'); });

      this.classList.add('tc-active');

      var target = section.querySelector('.tc-content[data-content="' + this.dataset.tab + '"]');
      if (target) target.classList.add('tc-content-active');

      if (window.innerWidth <= 767 && navWrapper) {
        var scrollLeft = this.offsetLeft - navWrapper.offsetWidth / 2 + this.offsetWidth / 2;
        navWrapper.scrollTo({ left: scrollLeft, behavior: 'smooth' });
      }
    });
  });
})();
</script>

