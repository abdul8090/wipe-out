<style>
  #shopify-section-{{ section.id }} {
    --wo-kr-bg: {{ section.settings.bg_color }};
    --wo-kr-text: {{ section.settings.text_color }};
    --wo-kr-muted: {{ section.settings.muted_color }};
    --wo-kr-eyebrow: {{ section.settings.eyebrow_color }};
    --wo-kr-border: {{ section.settings.border_color }};
    --wo-kr-icon-bg: {{ section.settings.icon_bg }};
    --wo-kr-icon: {{ section.settings.icon_color }};
  }

  .wo-kr {
    background: var(--wo-kr-bg);
    color: var(--wo-kr-text);
  }

  .wo-kr__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(64px, 8vw, 108px) 24px;
    text-align: center;
  }

  .wo-kr__eyebrow {
    font-size: 12.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--wo-kr-eyebrow);
    font-weight: 700;
    margin-bottom: 14px;
  }

  .wo-kr__heading {
    font-family: 'Assistant', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    font-size: clamp(32px, 5.2vw, 64px);
    line-height: 0.95;
    margin: 0 auto 18px;
    max-width: 14ch;
  }

  .wo-kr__sub {
    font-size: 16px;
    color: var(--wo-kr-muted);
    max-width: 620px;
    margin: 0 auto 56px;
    line-height: 1.6;
  }

  .wo-kr__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    text-align: left;
  }

  .wo-kr__card {
    border: 1px solid var(--wo-kr-border);
    border-radius: 6px;
    padding: 32px 28px;
  }

  .wo-kr__icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--wo-kr-icon-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--wo-kr-icon);
  }

  .wo-kr__card-title {
    font-family: 'Assistant', sans-serif;
    font-weight: 800;
    font-size: 19px;
    margin: 0 0 9px;
    text-transform: uppercase;
  }

  .wo-kr__card-desc {
    font-size: 14px;
    color: var(--wo-kr-muted);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 1023px) {
    .wo-kr__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 599px) {
    .wo-kr__grid {
      grid-template-columns: 1fr;
    }

    .wo-kr__sub {
      margin-bottom: 36px;
    }
  }
</style>

<section class="wo-kr">
  <div class="wo-kr__inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="wo-kr__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2 class="wo-kr__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}
      <p class="wo-kr__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="wo-kr__grid">
      {%- for block in section.blocks -%}
        <div class="wo-kr__card" {{ block.shopify_attributes }}>
          <div class="wo-kr__icon-wrap">
            {%- case block.settings.icon -%}
              {%- when 'lightning' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h6l-1 8 9-12h-6l1-8z"></path></svg>
              {%- when 'shield' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.6-3 7.6-7 9-4-1.4-7-4.4-7-9V6l7-3z"></path></svg>
              {%- when 'wind' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10a2.5 2.5 0 1 0-2.5-2.5"></path><path d="M3 12h14a2.5 2.5 0 1 1-2.5 2.5"></path><path d="M3 16h8a2.5 2.5 0 1 1-2.5 2.5"></path></svg>
              {%- when 'home' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-7 9 7"></path><path d="M5 10v9h14v-9"></path></svg>
              {%- when 'leaf' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
              {%- when 'star' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z"></path></svg>
              {%- else -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"></path></svg>
            {%- endcase -%}
          </div>
          <h3 class="wo-kr__card-title">{{ block.settings.title }}</h3>
          <p class="wo-kr__card-desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WipeOut Kills & Repels",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kills on contact. Repels for weeks."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Instant knockdown, then a long-lasting protective barrier that keeps insects from coming back — with zero smell."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text colour",
      "default": "#6b6864"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow colour",
      "default": "#9b1f1f"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border colour",
      "default": "#ebe9e6"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon background colour",
      "default": "#f5f2ee"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon colour",
      "default": "#181512"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lightning", "label": "Lightning bolt" },
            { "value": "shield", "label": "Shield" },
            { "value": "wind", "label": "Wind / Odourless" },
            { "value": "home", "label": "Home" },
            { "value": "leaf", "label": "Leaf / Natural" },
            { "value": "star", "label": "Star" }
          ],
          "default": "lightning"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Instant Knockdown"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Super-strength formula drops insects on contact — no waiting, no mixing."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WipeOut Kills & Repels",
      "blocks": [
        { "type": "feature", "settings": { "icon": "lightning", "title": "Instant Knockdown", "description": "Super-strength formula drops insects on contact — no waiting, no mixing." } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Lasting Barrier", "description": "Leaves a repellent layer on surfaces that keeps working for weeks after spraying." } },
        { "type": "feature", "settings": { "icon": "wind", "title": "Odourless", "description": "No bad smell, no harsh fumes — comfortable to use anywhere in the home." } }
      ]
    }
  ]
}
{% endschema %}
