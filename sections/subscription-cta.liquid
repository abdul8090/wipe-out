      "label": "Badge Text",
      "default": "350,000+ Happy Customers"
    },
    {
      "type": "image_picker",
      "id": "avatar_1",
      "label": "Customer Avatar 1"
    },
    {
      "type": "image_picker",
      "id": "avatar_2",
      "label": "Customer Avatar 2"
    },
    {
      "type": "image_picker",
      "id": "avatar_3",
      "label": "Customer Avatar 3"
    },
    {
      "type": "header",
      "content": "Benefits"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1",
      "default": "100% Guarantee"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2",
      "default": "Free Express Shipping"
    },
    {
      "type": "text",
      "id": "benefit_3",
