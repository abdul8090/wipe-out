<style>
  /* CSS custom properties — all controlled from section settings */
  #shopify-section-{{ section.id }} {
    --cta-bg:         {{ section.settings.background_color }};
    --cta-border:     {{ section.settings.border_color }};
    --cta-text:       {{ section.settings.text_color }};
    --cta-highlight:  {{ section.settings.highlight_color }};
    --cta-btn-bg:     {{ section.settings.button_color }};
    --cta-btn-shadow: {{ section.settings.button_shadow_color }};
    --cta-badge-bg:   {{ section.settings.badge_bg }};
  }

  /* Section wrapper */
  #shopify-section-{{ section.id }} .wo-cta_section {
    position: relative;
    overflow: hidden;
    font-family: {{ settings.type_body_font_family }}, sans-serif;
    background-color: var(--cta-bg);
    border-top: 1px solid var(--cta-border);
    border-bottom: 1px solid var(--cta-border);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .wo-cta_container {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    padding: 0 1em;
  }

  #shopify-section-{{ section.id }} .wo-cta_content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Badge */
  #shopify-section-{{ section.id }} .wo-cta_badge {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.75em;
    margin-bottom: 1.5em;
    border-radius: 999px;
    border: 1px solid var(--cta-border);
    background: var(--cta-badge-bg);
    padding: 4px 12px 4px 4px;
  }

  #shopify-section-{{ section.id }} .wo-cta_avatars {
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .wo-cta_avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--cta-bg);
    margin-left: -10px;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .wo-cta_avatar:first-child {
    margin-left: 0;
  }

  #shopify-section-{{ section.id }} .wo-cta_badge-text {
    font-size: {{ section.settings.badge_text_size }}px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    color: var(--cta-text);
  }

  /* Heading */
  #shopify-section-{{ section.id }} .wo-cta_heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    margin-bottom: 0.5em;
    line-height: 1.2;
    font-family: {{ settings.type_header_font_family }}, sans-serif;
    color: var(--cta-text);
  }

  #shopify-section-{{ section.id }} .wo-cta_highlight {
    color: var(--cta-highlight);
  }

  /* Description */
  #shopify-section-{{ section.id }} .wo-cta_description {
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.5;
    margin-bottom: 20px;
    color: var(--cta-text);
  }

  /* Button */
  #shopify-section-{{ section.id }} .wo-cta_button {
    display: inline-block;
    font-weight: 700;
    font-size: {{ section.settings.button_size }}px;
    padding: 0.875em 2em;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    border-radius: 12px;
    border-top: 1px solid var(--cta-border);
    border-right: 1px solid var(--cta-border);
    border-left: 1px solid var(--cta-border);
    background-color: var(--cta-btn-bg);
    color: var(--cta-text);
    box-shadow: 0px 4px 0px 0px var(--cta-btn-shadow);
  }

  #shopify-section-{{ section.id }} .wo-cta_button:hover {
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .wo-cta_button:active {
    transform: translateY(2px);
    box-shadow: 0px 2px 0px -1px var(--cta-btn-shadow);
  }

  /* Benefits */
  #shopify-section-{{ section.id }} .wo-cta_benefits {
    display: flex;
    justify-content: center;
    gap: 2em;
    margin-top: 2em;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .wo-cta_benefit {
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  #shopify-section-{{ section.id }} .wo-cta_icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5em;
    height: 1.5em;
    border-radius: 50%;
    font-size: 0.875em;
    font-weight: 700;
    background-color: var(--cta-btn-bg);
    border: 1px solid var(--cta-border);
  }

  #shopify-section-{{ section.id }} .wo-cta_text {
    font-size: {{ section.settings.benefit_text_size }}px;
    font-weight: 500;
    color: var(--cta-text);
  }

  /* Positioned images */
  #shopify-section-{{ section.id }} .wo-cta_image-left,
  #shopify-section-{{ section.id }} .wo-cta_image-right {
    position: absolute;
    top: 0;
    height: 100%;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .wo-cta_image-left {
    left: 0;
  }

  #shopify-section-{{ section.id }} .wo-cta_image-right {
    right: 0;
  }

  #shopify-section-{{ section.id }} .wo-cta_image-left img,
  #shopify-section-{{ section.id }} .wo-cta_image-right img {
    max-height: 100%;
    width: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .wo-cta_image-mobile {
    display: none;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .wo-cta_image-mobile img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    margin: 0 auto;
    object-fit: contain;
    object-position: bottom center;
  }

  /* Responsive */
  @media (max-width: 1315px) {
    #shopify-section-{{ section.id }} .wo-cta_image-left  { left: -8px; }
    #shopify-section-{{ section.id }} .wo-cta_image-right { right: -80px; }
  }

  @media (max-width: 1300px) {
    #shopify-section-{{ section.id }} .wo-cta_image-left  { left: -100px; }
    #shopify-section-{{ section.id }} .wo-cta_image-right { right: -100px; }
  }

  @media (min-width: 750px) and (max-width: 1415px) {
    #shopify-section-{{ section.id }} .wo-cta_content { max-width: 540px; }
  }

  @media (max-width: 1100px) {
    #shopify-section-{{ section.id }} .wo-cta_image-left  { left: -80px; }
    #shopify-section-{{ section.id }} .wo-cta_image-right { right: -80px; }

    #shopify-section-{{ section.id }} .wo-cta_image-left img,
    #shopify-section-{{ section.id }} .wo-cta_image-right img {
      max-width: 250px;
    }
  }

  /* Mobile — images swap, padding from settings */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .wo-cta_section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .wo-cta_heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: 12px;
    }

    #shopify-section-{{ section.id }} .wo-cta_description {
      font-size: {{ section.settings.description_size_mobile }}px;
      margin-bottom: 12px;
    }

    #shopify-section-{{ section.id }} .wo-cta_image-left,
    #shopify-section-{{ section.id }} .wo-cta_image-right {
      display: none;
    }

    #shopify-section-{{ section.id }} .wo-cta_image-mobile {
      display: block;
    }

    #shopify-section-{{ section.id }} .wo-cta_benefits {
      justify-content: center;
      align-items: center;
      gap: 9px;
      align-self: stretch;
      margin-top: 12px;
    }

    #shopify-section-{{ section.id }} .wo-cta_avatar {
      width: 30px;
      height: 30px;
    }

    #shopify-section-{{ section.id }} .wo-cta_badge {
      gap: 4px;
    }

    #shopify-section-{{ section.id }} .wo-cta_button {
      width: 100%;
      padding: 0.75em 1.5em;
    }
  }
</style>

<div class="wo-cta_section">
  {%- if section.settings.image_mobile != blank -%}
    <div class="wo-cta_image-mobile">
      {%- assign mob_alt = section.settings.button_text | default: 'Product Image' | escape -%}
      {{
        section.settings.image_mobile
        | image_url: width: 800
        | image_tag: loading: 'lazy', alt: mob_alt, widths: '400, 600, 800'
      }}
    </div>
  {%- else -%}
    <div class="wo-cta_image-mobile">
      <img
        src="https://placehold.co/800x300/{{ section.settings.background_color | remove: '#' }}/1d211e?text=Product+Image"
        alt="Product Image"
        width="800"
        height="300"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="wo-cta_container">
    <div class="wo-cta_content">

      {%- if section.settings.show_customer_badge -%}
        <div class="wo-cta_badge">
          <div class="wo-cta_avatars">
            {%- if section.settings.avatar_1 != blank -%}
              {{
                section.settings.avatar_1
                | image_url: width: 80, height: 80, crop: 'center'
                | image_tag: loading: 'lazy', alt: 'Customer', class: 'wo-cta_avatar', width: 40, height: 40
              }}
            {%- else -%}
              <img class="wo-cta_avatar" src="https://placehold.co/40x40/1d211e/ffffff" alt="Customer" width="40" height="40">
            {%- endif -%}

            {%- if section.settings.avatar_2 != blank -%}
              {{
                section.settings.avatar_2
                | image_url: width: 80, height: 80, crop: 'center'
                | image_tag: loading: 'lazy', alt: 'Customer', class: 'wo-cta_avatar', width: 40, height: 40
              }}
            {%- else -%}
              <img class="wo-cta_avatar" src="https://placehold.co/40x40/1d211e/ffffff" alt="Customer" width="40" height="40">
            {%- endif -%}

            {%- if section.settings.avatar_3 != blank -%}
              {{
                section.settings.avatar_3
                | image_url: width: 80, height: 80, crop: 'center'
                | image_tag: loading: 'lazy', alt: 'Customer', class: 'wo-cta_avatar', width: 40, height: 40
              }}
            {%- else -%}
              <img class="wo-cta_avatar" src="https://placehold.co/40x40/1d211e/ffffff" alt="Customer" width="40" height="40">
            {%- endif -%}
          </div>
          <span class="wo-cta_badge-text">{{- section.settings.badge_text -}}</span>
        </div>
      {%- endif -%}

      <h2 class="wo-cta_heading">
        {%- if section.settings.highlight_text != blank -%}
          <span class="wo-cta_highlight">{{- section.settings.highlight_text -}}</span>
        {%- endif -%}
        {{ section.settings.heading }}
      </h2>

      <p class="wo-cta_description">{{ section.settings.description }}</p>

      <a
        href="{% if section.settings.button_link != blank %}{{ section.settings.button_link }}{% else %}#{% endif %}"
        class="wo-cta_button"
        {% unless section.settings.button_link != blank %}onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;"{% endunless %}
      >
        {{- section.settings.button_text -}}
      </a>

      <div class="wo-cta_benefits">
        {%- if section.settings.benefit_1 != blank -%}
          <div class="wo-cta_benefit">
            <span class="wo-cta_icon">✓</span>
            <span class="wo-cta_text">{{- section.settings.benefit_1 -}}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.benefit_2 != blank -%}
          <div class="wo-cta_benefit">
            <span class="wo-cta_icon">✓</span>
            <span class="wo-cta_text">{{- section.settings.benefit_2 -}}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.benefit_3 != blank -%}
          <div class="wo-cta_benefit">
            <span class="wo-cta_icon">✓</span>
            <span class="wo-cta_text">{{- section.settings.benefit_3 -}}</span>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>

  {%- if section.settings.image_left != blank -%}
    <div class="wo-cta_image-left">
      {%- assign left_alt = section.settings.heading | default: 'Product Image' | escape -%}
      {{
        section.settings.image_left
        | image_url: width: 800
        | image_tag: loading: 'lazy', alt: left_alt, widths: '300, 500, 800'
      }}
    </div>
  {%- else -%}
    <div class="wo-cta_image-left">
      <img
        src="https://placehold.co/400x600/{{ section.settings.background_color | remove: '#' }}/1d211e?text=Product+Image"
        alt="Product Image"
        width="400"
        height="600"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  {%- if section.settings.image_right != blank -%}
    <div class="wo-cta_image-right">
      {%- assign right_alt = section.settings.heading | default: 'Product Image' | escape -%}
      {{
        section.settings.image_right
        | image_url: width: 800
        | image_tag: loading: 'lazy', alt: right_alt, widths: '300, 500, 800'
      }}
    </div>
  {%- else -%}
    <div class="wo-cta_image-right">
      <img
        src="https://placehold.co/400x600/{{ section.settings.background_color | remove: '#' }}/1d211e?text=Product+Image"
        alt="Product Image"
        width="400"
        height="600"
        loading="lazy"
      >
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Subscription CTA",
  "tag": "section",
  "class": "subscription-cta-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlighted Heading Text",
      "default": "RISK-FREE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BEAUTY REVOLUTION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We believe in our balm because it actually works. If your skin isn't looking better in 30 days, we'll give you your money back — no drama, no hoops. Subscribe now and save 30% on your first order!"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Subscribe & Save 30% Today"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Customer Badge"
    },
    {
      "type": "checkbox",
      "id": "show_customer_badge",
      "label": "Show Customer Badge",
      "default": true
    },
    {
      "type": "inline_richtext",
