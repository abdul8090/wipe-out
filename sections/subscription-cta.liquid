    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": 64,
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
