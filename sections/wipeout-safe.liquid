<style>
  #shopify-section-{{ section.id }} {
    --wo-safe-bg: {{ section.settings.bg_color }};
    --wo-safe-text: {{ section.settings.text_color }};
    --wo-safe-muted: {{ section.settings.muted_color }};
    --wo-safe-icon: {{ section.settings.icon_color }};
    --wo-safe-pill-border: {{ section.settings.pill_border }};
    --wo-safe-border: {{ section.settings.border_color }};
  }

  .wo-safe {
    border-top: 1px solid var(--wo-safe-border);
    border-bottom: 1px solid var(--wo-safe-border);
    background: var(--wo-safe-bg);
    color: var(--wo-safe-text);
  }

  .wo-safe__inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(56px, 7vw, 92px) 24px;
    text-align: center;
  }

  .wo-safe__icon {
    color: var(--wo-safe-icon);
    margin-bottom: 22px;
    display: inline-block;
  }

  .wo-safe__heading {
    font-family: 'Archivo', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    font-size: clamp(28px, 4.2vw, 50px);
    line-height: 0.98;
    margin: 0 0 16px;
  }

  .wo-safe__desc {
    font-size: 16px;
    color: var(--wo-safe-muted);
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .wo-safe__pills {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .wo-safe__pill {
    border: 1px solid var(--wo-safe-pill-border);
    border-radius: 40px;
    padding: 11px 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--wo-safe-text);
    background: transparent;
  }

  @media (max-width: 479px) {
    .wo-safe__pills {
      gap: 10px;
    }

    .wo-safe__pill {
      padding: 9px 16px;
      font-size: 12px;
    }
  }
</style>

<section class="wo-safe">
  <div class="wo-safe__inner">
    <div class="wo-safe__icon">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.6-3 7.6-7 9-4-1.4-7-4.4-7-9V6l7-3z"></path><path d="M9 12l2 2 4-4"></path></svg>
    </div>
    <h2 class="wo-safe__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.description != blank -%}
      <p class="wo-safe__desc">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="wo-safe__pills">
        {%- for block in section.blocks -%}
          <span class="wo-safe__pill" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "WipeOut Safe Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Safe for home, kids & pets"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A non-toxic, odourless formula designed for indoor use. Powerful on pests, gentle on the home you share."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Section border colour",
      "default": "#ebe9e6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Description text colour",
      "default": "#6b6864"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon colour",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "pill_border",
      "label": "Pill border colour",
      "default": "#d9d4cd"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Safety pill",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Non-toxic formula"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WipeOut Safe Section",
      "blocks": [
        { "type": "pill", "settings": { "label": "Non-toxic formula" } },
        { "type": "pill", "settings": { "label": "Safe around kids" } },
        { "type": "pill", "settings": { "label": "Safe for pets" } },
        { "type": "pill", "settings": { "label": "Odourless" } }
      ]
    }
  ]
}
{% endschema %}
