    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header strip background",
      "default": "#faf9f7"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border colour",
      "default": "#ebe9e6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text colour",
      "default": "#6b6864"
    },
    {
      "type": "color",
      "id": "item_img_bg",
      "label": "Item image background",
      "default": "#faf8f7"
    },
    {
      "type": "color",
      "id": "progress_bg",
      "label": "Progress bar track colour",
      "default": "#e9e6e1"
    },
    {
      "type": "color",
      "id": "progress_fill",
      "label": "Progress bar fill colour",
      "default": "#9b1f1f"
    },
    {
      "type": "color",
      "id": "checkout_btn_bg",
      "label": "Checkout button background",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "checkout_btn_text",
      "label": "Checkout button text colour",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "WipeOut Cart Drawer"
    }
  ]
}
{% endschema %}
