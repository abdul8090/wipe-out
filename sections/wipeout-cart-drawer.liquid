<style>
  #shopify-section-{{ section.id }} {
    --wo-cd-bg: {{ section.settings.bg_color }};
    --wo-cd-text: {{ section.settings.text_color }};
    --wo-cd-muted: {{ section.settings.muted_color }};
    --wo-cd-border: {{ section.settings.border_color }};
    --wo-cd-header-bg: {{ section.settings.header_bg }};
    --wo-cd-item-img-bg: {{ section.settings.item_img_bg }};
    --wo-cd-progress-bg: {{ section.settings.progress_bg }};
    --wo-cd-progress-fill: {{ section.settings.progress_fill }};
    --wo-cd-btn-bg: {{ section.settings.checkout_btn_bg }};
    --wo-cd-btn-text: {{ section.settings.checkout_btn_text }};
    --wo-cd-overlay-bg: rgba(24, 21, 18, 0.4);
  }

  .wo-cd-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: var(--wo-cd-overlay-bg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .wo-cd-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .wo-cd {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 91;
    width: min(420px, 92vw);
    background: var(--wo-cd-bg);
    box-shadow: -20px 0 60px -30px rgba(24, 21, 18, 0.5);
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.7, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    color: var(--wo-cd-text);
  }

  .wo-cd.is-open {
    transform: translateX(0);
  }

  .wo-cd__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    border-bottom: 1px solid var(--wo-cd-border);
    flex-shrink: 0;
  }

  .wo-cd__title {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .wo-cd__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    color: var(--wo-cd-text);
    transition: opacity 0.2s;
  }

  .wo-cd__close:hover {
    opacity: 0.6;
  }

  .wo-cd__progress-wrap {
    padding: 14px 24px;
    border-bottom: 1px solid var(--wo-cd-border);
    background: var(--wo-cd-header-bg);
    flex-shrink: 0;
  }

  .wo-cd__progress-msg {
    font-size: 12.5px;
    color: var(--wo-cd-muted);
    margin-bottom: 8px;
  }

  .wo-cd__progress-bar {
    height: 6px;
    background: var(--wo-cd-progress-bg);
    border-radius: 4px;
    overflow: hidden;
  }

  .wo-cd__progress-fill {
    height: 100%;
    background: var(--wo-cd-progress-fill);
    border-radius: 4px;
    transition: width 0.4s;
  }

  .wo-cd__items {
    flex: 1;
    overflow-y: auto;
    padding: 8px 24px;
  }

  .wo-cd__empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--wo-cd-muted);
  }

  .wo-cd__empty-icon {
    color: #cfc9c1;
    margin-bottom: 16px;
  }

  .wo-cd__empty-text {
    font-size: 15px;
    margin: 0 0 18px;
  }

  .wo-cd__empty-btn {
    background: var(--wo-cd-text);
    color: var(--wo-cd-bg);
    border: none;
    border-radius: 4px;
    padding: 13px 26px;
    font-weight: 700;
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
  }

  .wo-cd__item {
    display: flex;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid var(--wo-cd-border);
  }

  .wo-cd__item-img {
    width: 66px;
    height: 66px;
    border-radius: 6px;
    background: var(--wo-cd-item-img-bg);
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wo-cd__item-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wo-cd__item-body {
    flex: 1;
    min-width: 0;
  }

  .wo-cd__item-name {
    font-weight: 700;
    font-size: 14px;
    line-height: 1.3;
    margin-bottom: 4px;
  }

  .wo-cd__item-price {
    font-size: 13px;
    color: var(--wo-cd-muted);
    margin-bottom: 10px;
  }

  .wo-cd__item-controls {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .wo-cd__qty {
    display: flex;
    align-items: center;
    border: 1px solid var(--wo-cd-border);
    border-radius: 5px;
    overflow: hidden;
  }

  .wo-cd__qty-btn {
    background: none;
    border: none;
    width: 30px;
    height: 30px;
    cursor: pointer;
    font-size: 17px;
    color: var(--wo-cd-text);
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .wo-cd__qty-btn:hover {
    background: var(--wo-cd-header-bg);
  }

  .wo-cd__qty-val {
    min-width: 26px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: var(--wo-cd-text);
  }

  .wo-cd__remove {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 12.5px;
    color: var(--wo-cd-muted);
    text-decoration: underline;
    font-family: inherit;
  }

  .wo-cd__item-total {
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }

  .wo-cd__footer {
    border-top: 1px solid var(--wo-cd-border);
    padding: 20px 24px;
    flex-shrink: 0;
  }

  .wo-cd__subtotal-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .wo-cd__subtotal-label {
    font-size: 14px;
    color: var(--wo-cd-muted);
  }

  .wo-cd__subtotal-val {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: 20px;
  }

  .wo-cd__checkout-btn {
    display: block;
    width: 100%;
    background: var(--wo-cd-btn-bg);
    color: var(--wo-cd-btn-text);
    border: none;
    border-radius: 4px;
    padding: 16px;
    font-weight: 700;
    font-size: 15px;
    font-family: inherit;
    cursor: pointer;
    letter-spacing: 0.02em;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .wo-cd__checkout-btn:hover {
    opacity: 0.88;
  }

  .wo-cd__shipping-note {
    font-size: 12px;
    color: var(--wo-cd-muted);
    text-align: center;
    margin-top: 10px;
  }
</style>

<div class="wo-cd-overlay" id="wo-cd-overlay-{{ section.id }}" aria-hidden="true"></div>

<div class="wo-cd" id="wo-cd-{{ section.id }}" role="dialog" aria-modal="true" aria-label="{{ section.settings.title }}" aria-hidden="true">
  <div class="wo-cd__header">
    <div class="wo-cd__title">{{ section.settings.title }}</div>
    <button class="wo-cd__close" id="wo-cd-close-{{ section.id }}" aria-label="Close cart">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
    </button>
  </div>

  {%- if section.settings.show_free_shipping_bar -%}
    <div class="wo-cd__progress-wrap" id="wo-cd-progress-{{ section.id }}">
      <div class="wo-cd__progress-msg" id="wo-cd-progress-msg-{{ section.id }}">
        {{- section.settings.free_shipping_text -}}
      </div>
      <div class="wo-cd__progress-bar">
        <div class="wo-cd__progress-fill" id="wo-cd-progress-fill-{{ section.id }}" style="width:0%"></div>
      </div>
    </div>
  {%- endif -%}

  <div class="wo-cd__items" id="wo-cd-items-{{ section.id }}">
    {%- if cart == empty -%}
      <div class="wo-cd__empty">
        <div class="wo-cd__empty-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2.2l2.1 12.4a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.8L20.5 8H6"></path><circle cx="9.5" cy="20" r="1.3"></circle><circle cx="17.5" cy="20" r="1.3"></circle></svg>
        </div>
        <p class="wo-cd__empty-text">{{ section.settings.empty_text }}</p>
        <button class="wo-cd__empty-btn" id="wo-cd-continue-{{ section.id }}">{{ section.settings.continue_label }}</button>
      </div>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="wo-cd__item" data-key="{{ item.key }}">
          <div class="wo-cd__item-img">
            {%- if item.image != blank -%}
              {%- assign item_alt = item.title | escape -%}
              {{ item.image | image_url: width: 132 | image_tag: alt: item_alt, loading: 'lazy' }}
            {%- endif -%}
          </div>
          <div class="wo-cd__item-body">
            <div class="wo-cd__item-name">{{ item.product.title }}</div>
            <div class="wo-cd__item-price">{{ item.final_price | money }}</div>
            <div class="wo-cd__item-controls">
              <div class="wo-cd__qty">
                <button class="wo-cd__qty-btn" data-action="decrease" data-key="{{ item.key }}" aria-label="Decrease quantity">&ndash;</button>
                <span class="wo-cd__qty-val">{{ item.quantity }}</span>
                <button class="wo-cd__qty-btn" data-action="increase" data-key="{{ item.key }}" aria-label="Increase quantity">+</button>
              </div>
              <button class="wo-cd__remove" data-key="{{ item.key }}" aria-label="Remove {{ item.title }}">{{ section.settings.remove_label }}</button>
            </div>
          </div>
          <div class="wo-cd__item-total">{{ item.final_line_price | money }}</div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- unless cart == empty -%}
    <div class="wo-cd__footer" id="wo-cd-footer-{{ section.id }}">
      <div class="wo-cd__subtotal-row">
        <span class="wo-cd__subtotal-label">{{ section.settings.subtotal_label }}</span>
        <span class="wo-cd__subtotal-val" id="wo-cd-total-{{ section.id }}">{{ cart.total_price | money }}</span>
      </div>
      <a class="wo-cd__checkout-btn" href="{{ routes.checkout }}">{{ section.settings.checkout_label }}</a>
      {%- if section.settings.shipping_note != blank -%}
        <p class="wo-cd__shipping-note">{{ section.settings.shipping_note }}</p>
      {%- endif -%}
    </div>
  {%- endunless -%}
</div>

<script>
(function () {
  var sectionId = '{{ section.id }}';
  var drawer = document.getElementById('wo-cd-' + sectionId);
  var overlay = document.getElementById('wo-cd-overlay-' + sectionId);
  var closeBtn = document.getElementById('wo-cd-close-' + sectionId);
  var continueBtn = document.getElementById('wo-cd-continue-' + sectionId);

  {%- if section.settings.show_free_shipping_bar -%}
  var freeThreshold = {{ section.settings.free_shipping_threshold | times: 100 }};
  {%- endif -%}

  function openDrawer() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    updateCart();
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function updateCart() {
    fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        renderItems(cart);
        {%- if section.settings.show_free_shipping_bar -%}
        updateProgress(cart.total_price);
        {%- endif -%}
        var totalEl = document.getElementById('wo-cd-total-' + sectionId);
        if (totalEl) totalEl.textContent = formatMoney(cart.total_price);
      });
  }

  function formatMoney(cents) {
    return '£' + (cents / 100).toFixed(2);
  }

  function renderItems(cart) {
    var itemsEl = document.getElementById('wo-cd-items-' + sectionId);
    var footerEl = document.getElementById('wo-cd-footer-' + sectionId);
    if (!itemsEl) return;

    if (cart.item_count === 0) {
      itemsEl.innerHTML = '<div class="wo-cd__empty"><div class="wo-cd__empty-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2.2l2.1 12.4a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.8L20.5 8H6"></path><circle cx="9.5" cy="20" r="1.3"></circle><circle cx="17.5" cy="20" r="1.3"></circle></svg></div><p class="wo-cd__empty-text">{{ section.settings.empty_text | escape }}</p><button class="wo-cd__empty-btn" onclick="document.getElementById(\'wo-cd-close-' + sectionId + '\').click()">{{ section.settings.continue_label | escape }}</button></div>';
      if (footerEl) footerEl.style.display = 'none';
      return;
    }

    if (footerEl) {
      footerEl.style.display = '';
      var totalEl = footerEl.querySelector('#wo-cd-total-' + sectionId);
      if (totalEl) totalEl.textContent = formatMoney(cart.total_price);
    }

    var html = cart.items.map(function (item) {
      var img = item.image ? '<img src="' + item.image.replace(/(\.[^.]+)$/, '_132x132$1') + '" alt="" loading="lazy">' : '';
      return '<div class="wo-cd__item" data-key="' + item.key + '"><div class="wo-cd__item-img">' + img + '</div><div class="wo-cd__item-body"><div class="wo-cd__item-name">' + item.product_title + '</div><div class="wo-cd__item-price">' + formatMoney(item.final_price) + '</div><div class="wo-cd__item-controls"><div class="wo-cd__qty"><button class="wo-cd__qty-btn" data-action="decrease" data-key="' + item.key + '" aria-label="Decrease">&ndash;</button><span class="wo-cd__qty-val">' + item.quantity + '</span><button class="wo-cd__qty-btn" data-action="increase" data-key="' + item.key + '" aria-label="Increase">+</button></div><button class="wo-cd__remove" data-key="' + item.key + '">{{ section.settings.remove_label | escape }}</button></div></div><div class="wo-cd__item-total">' + formatMoney(item.final_line_price) + '</div></div>';
    }).join('');
    itemsEl.innerHTML = html;
    bindItemEvents();
  }

  {%- if section.settings.show_free_shipping_bar -%}
  function updateProgress(totalCents) {
    var msgEl = document.getElementById('wo-cd-progress-msg-' + sectionId);
    var fillEl = document.getElementById('wo-cd-progress-fill-' + sectionId);
    if (!msgEl || !fillEl) return;
    if (totalCents >= freeThreshold) {
      msgEl.textContent = '{{ section.settings.free_shipping_achieved | escape }}';
      fillEl.style.width = '100%';
    } else {
      var remaining = formatMoney(freeThreshold - totalCents);
      msgEl.textContent = '{{ section.settings.free_shipping_text | escape }}'.replace('[amount]', remaining);
      fillEl.style.width = Math.min(100, (totalCents / freeThreshold) * 100) + '%';
    }
  }
  {%- endif -%}

  function bindItemEvents() {
    var itemsEl = document.getElementById('wo-cd-items-' + sectionId);
    if (!itemsEl) return;
    itemsEl.querySelectorAll('.wo-cd__qty-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var key = btn.dataset.key;
        var qtyEl = btn.closest('.wo-cd__qty').querySelector('.wo-cd__qty-val');
        var qty = parseInt(qtyEl.textContent);
        var newQty = btn.dataset.action === 'increase' ? qty + 1 : Math.max(0, qty - 1);
        changeQty(key, newQty);
      });
    });
    itemsEl.querySelectorAll('.wo-cd__remove').forEach(function (btn) {
      btn.addEventListener('click', function () { changeQty(btn.dataset.key, 0); });
    });
  }

  function changeQty(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function () { updateCart(); });
  }

  if (overlay) overlay.addEventListener('click', closeDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeDrawer();
  });

  document.addEventListener('click', function (e) {
    var trigger = e.target.closest('[data-wo-cart-open]');
    if (trigger) { e.preventDefault(); openDrawer(); }
  });

  window.woOpenCart = openDrawer;

  bindItemEvents();
})();
</script>

{% schema %}
{
  "name": "WipeOut Cart Drawer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Drawer title",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "continue_label",
      "label": "Continue shopping label",
      "default": "Start shopping"
    },
    {
      "type": "text",
      "id": "remove_label",
      "label": "Remove item label",
      "default": "Remove"
    },
    {
      "type": "text",
      "id": "subtotal_label",
      "label": "Subtotal label",
      "default": "Subtotal"
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Checkout button label",
      "default": "Checkout"
    },
    {
      "type": "text",
      "id": "shipping_note",
      "label": "Shipping note below checkout",
      "default": "Shipping & taxes calculated at checkout"
    },
    {
      "type": "header",
      "content": "Free shipping bar"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping_bar",
      "label": "Show free shipping progress bar",
      "default": true
    },
    {
      "type": "number",
