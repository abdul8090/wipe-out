    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#181512"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text colour",
      "default": "#6b6864"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow colour",
      "default": "#9b1f1f"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border colour",
      "default": "#ebe9e6"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Title (if no product selected)",
          "default": "Killer Spray"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card description",
          "default": "Kills insects on contact. Protects your home."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price (if no product selected)",
          "default": "£14.99"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare-at price (if no product selected)"
        },
        {
          "type": "text",
          "id": "save_label",
          "label": "Save label (e.g. SAVE 25%)"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text (e.g. Bed Bug)"
        },
        {
          "type": "text",
          "id": "secondary_badge",
          "label": "Secondary badge (e.g. Best Seller)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Add to cart"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent colour (badge, button, save label)",
          "default": "#9b1f1f"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Image background colour",
          "default": "#faf8f7"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WipeOut Shop by Pest",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "badge_text": "Bed Bug",
