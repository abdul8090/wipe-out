          "type": "faq_item",
          "settings": {
            "question": "Is WipeOut safe around children and pets?",
            "answer": "Yes. Once the treated surface is dry — typically within 30 minutes — it is safe for children and pets to re-enter the area. We recommend ventilating the room during application.",
            "open_by_default": false
          }
        },
        "faq_item_34m3iQ": {
          "type": "faq_item",
          "settings": {
            "question": "What pests does WipeOut work against?",
            "answer": "WipeOut is effective against cockroaches, termites, bed bugs, ants, spiders, mosquitoes, and most common household pests. Check the product label for a full species list.",
            "open_by_default": false
          }
        },
        "faq_item_X3a9g3": {
          "type": "faq_item",
          "settings": {
            "question": "How long does WipeOut's protection last?",
            "answer": "WipeOut's residual barrier keeps working for up to 12 weeks on non-porous surfaces. Frequency of application may vary depending on pest pressure and surface type.",
