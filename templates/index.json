          "type": "faq_item",
          "settings": {
            "question": "Is WipeOut safe to use around children and pets?",
            "answer": "Yes. WipeOut is a non-toxic, odourless formula specifically designed for indoor use. It is safe to use around children and pets once the treated surface has dried."
          }
        },
        "faq_item_3jHrB9": {
          "type": "faq_item",
          "settings": {
            "question": "How long does WipeOut keep working after application?",
            "answer": "WipeOut creates a long-lasting repellent barrier that keeps working for several weeks. For severe infestations, we recommend a second application after 7–10 days."
          }
        },
        "faq_item_DFEy74": {
          "type": "faq_item",
          "settings": {
            "question": "Does WipeOut have a smell?",
            "answer": "No. WipeOut is completely odourless. There are no harsh chemical fumes, making it comfortable to use in bedrooms, kitchens, and living spaces."
          }
        },
